# Database
DATABASE_URL=postgresql://user:password@localhost:5432/playpointpos

# Auth
JWT_ACCESS_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Server
PORT=4000

# Cloudinary (POST /upload/image — ảnh sản phẩm/game)
# Lấy tại: https://console.cloudinary.com → đăng ký/đăng nhập → Dashboard
# Vào: Account Details (hoặc Settings → Product environment credentials)
#   - Cloud name  → CLOUDINARY_CLOUD_NAME
#   - API Key     → CLOUDINARY_API_KEY
#   - API Secret  → CLOUDINARY_API_SECRET (chỉ hiện một lần khi tạo; lưu an toàn)
# Nếu bỏ trống 3 biến trên: server vẫn chạy nhưng upload ảnh trả 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Tuỳ chọn: thư mục trong Media Library (mặc định trong code: playpointpos)
CLOUDINARY_UPLOAD_FOLDER=playpointpos

# SMTP
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
SMTP_FROM=your_ethereal_user@ethereal.email
