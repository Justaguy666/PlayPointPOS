{
  "name": "API",
  "type": "module",
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "tscinit": "tsc --init",
    "server": "node --import tsx/esm src/index.ts",
    "build": "npx rimraf dist && tsc",
    "watch": "tsc -w",
    "migration:generate": "node --import tsx/esm ./node_modules/typeorm/cli.js migration:generate src/app/migrations/Migration -d src/config/database.ts",
    "migration:run": "node --import tsx/esm ./node_modules/typeorm/cli.js migration:run -d src/config/database.ts",
    "migration:revert": "node --import tsx/esm ./node_modules/typeorm/cli.js migration:revert -d src/config/database.ts"
  },
  "dependencies": {
    "@apollo/server": "^4",
    "argon2": "^0.44.0",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
