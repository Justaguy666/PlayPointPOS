<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI"
    xmlns:converters="using:WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Resources/FontSize.xaml" />
                <ResourceDictionary Source="ms-appx:///Resources/Colors.xaml" />
                <ResourceDictionary Source="ms-appx:///Resources/Images.xaml" />
                <ResourceDictionary Source="ms-appx:///Resources/Styles/CheckBoxStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BoolToVisibleConverter x:Key="BoolToVisible" />
            <converters:BoolToInvisibleConverter x:Key="BoolToInvisible" />
            <converters:BoolInverterConverter x:Key="BoolInverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
            <converters:BoolToOrangeBrushConverter x:Key="BoolToOrangeBrushConverter" />
            <converters:BoolToGradientBrushConverter x:Key="BoolToGradientBrushConverter" />
            <converters:IconConverter x:Key="IconConverter" />
            <converters:ChartValueToHeightConverter x:Key="ChartValueToHeightConverter" />

            <!-- Custom TextBox Style - Keep white background on focus, larger border radius -->
            <Style TargetType="TextBox">
                <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorderBrush}"/>
                <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12,10"/>
            </Style>

            <!-- Custom PasswordBox Style - Keep white background on focus, larger border radius -->
            <Style TargetType="PasswordBox">
                <Setter Property="BorderBrush" Value="{StaticResource TextBoxBorderBrush}"/>
                <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12,10"/>
            </Style>
            
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
