<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Images -->
    <ImageBrush x:Key="PatternBrush" 
                ImageSource="ms-appx:///Assets/Pattern.png" 
                Stretch="None"
                AlignmentX="Left"
                AlignmentY="Top" />
    
    <!-- Mock Images -->
    <ImageBrush x:Key="MockBrush"
                ImageSource="ms-appx:///Assets/Mock.png"
                Stretch="UniformToFill" 
                AlignmentX="Center"
                AlignmentY="Center" />

</ResourceDictionary>
