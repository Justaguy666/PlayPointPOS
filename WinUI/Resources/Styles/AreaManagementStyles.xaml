<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:WinUI.Helpers">

    <Style x:Key="SummarizedAreaCardBorderStyle"
           TargetType="Border">
        <Setter Property="Height" Value="160" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="BorderBrush" Value="{StaticResource SummarizedAreaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="helpers:CursorBehavior.UseHandCursor" Value="True" />
    </Style>

    <Style x:Key="DetailedAreaCardActionButtonStyle"
           TargetType="Button">
        <Setter Property="helpers:CursorBehavior.UseHandCursor" Value="True" />
        <Setter Property="Height" Value="38" />
        <Setter Property="MinWidth" Value="82" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource SuccessGreenBrush}" />
        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessGreenBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="DetailedAreaCardHeaderGridStyle"
           TargetType="Grid">
        <Setter Property="Height" Value="150" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Padding" Value="28,0,24,0" />
        <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource LightGrayBrush}" />
    </Style>

    <Style x:Key="DetailedAreaCardPrimaryButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DetailedAreaCardActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource SuccessGreenBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessGreenBrush}" />
    </Style>

    <Style x:Key="DetailedAreaCardSecondaryButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DetailedAreaCardActionButtonStyle}">
        <Setter Property="MinWidth" Value="94" />
        <Setter Property="Background" Value="{StaticResource InfoBlueBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoBlueBrush}" />
    </Style>

    <Style x:Key="DangerButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DetailedAreaCardActionButtonStyle}">
        <Setter Property="MinWidth" Value="94" />
        <Setter Property="Background" Value="{StaticResource DangerButtonBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBackgroundBrush}" />
    </Style>

    <Style x:Key="DetailedRentedSectionBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource SurfaceCardBorderStyle}">
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="DetailedRentedSectionActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource PrimaryActionButtonStyle}">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
    </Style>

    <Style x:Key="DetailedRentedServiceActionMenuButtonStyle"
           TargetType="Button">
        <Setter Property="helpers:CursorBehavior.UseHandCursor" Value="True" />
        <Setter Property="Width" Value="96" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BlackBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LightGrayBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeExtraSmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
</ResourceDictionary>
