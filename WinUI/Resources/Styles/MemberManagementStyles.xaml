<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="MemberCardNameTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameListNameTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeExtraExtraLarge}" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <Style x:Key="MemberCardMetaLabelTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameListMetaLabelTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
    </Style>

    <Style x:Key="MemberCardMetaValueTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameListMetaValueTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}" />
    </Style>

    <Style x:Key="MemberCardSpentTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameListPriceTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeExtraExtraLarge}" />
    </Style>

    <Style x:Key="MemberCardProgressTextStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="MemberCardBadgeTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameCardBadgeTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
