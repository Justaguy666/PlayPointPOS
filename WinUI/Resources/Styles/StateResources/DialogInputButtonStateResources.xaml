<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StaticResource x:Key="ButtonBackground" ResourceKey="WhiteBrush" />
    <StaticResource x:Key="ButtonForeground" ResourceKey="BlackBrush" />
    <StaticResource x:Key="ButtonBorderBrush" ResourceKey="LightGrayBrush" />
    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="VeryLightGrayBrush" />
    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="AntiqueWhiteBrush" />
    <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="BlackBrush" />
    <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="BlackBrush" />
    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="MediumGrayBrush" />
    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="OrangeFocusBrush" />
    <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="AntiqueWhiteBrush" />
    <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="MediumDarkGrayBrush" />
</ResourceDictionary>
