<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StaticResource x:Key="ButtonBackground" ResourceKey="InfoBlueBrush" />
    <StaticResource x:Key="ButtonForeground" ResourceKey="WhiteBrush" />
    <StaticResource x:Key="ButtonBorderBrush" ResourceKey="InfoBlueBrush" />
    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="InfoBlueDarkBrush" />
    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="InfoBlueDarkerBrush" />
    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="InfoBlueDarkBrush" />
    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="InfoBlueDarkerBrush" />
    <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="WhiteBrush" />
    <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="WhiteBrush" />
    <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="LighterGrayBrush" />
    <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="MediumDarkGrayBrush" />
</ResourceDictionary>
