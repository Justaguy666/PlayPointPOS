<ContentDialog
    x:Class="WinUI.Views.Dialogs.ConfigDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    CornerRadius="12"
    Background="{StaticResource WhiteBrush}"
    Width="1200"
    Height="Auto"
    HorizontalAlignment="Center"
    Padding="20">
    
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <PathIcon Grid.Column="0"
                      Width="22"
                      Height="22"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                      Foreground="{StaticResource BlackBrush}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.TitleDisplay, Mode=OneWay}"
                       FontSize="{StaticResource DialogHeaderFontSize}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BlackBrush}"/>
            <Button Grid.Column="2"
                    Width="32" Height="32"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="0"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipDisplay, Mode=OneWay}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AntiqueWhiteBrush"/>
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="LighterGrayBrush"/>
                </Button.Resources>
                <PathIcon Width="14"
                          Height="14"
                          Data="{x:Bind CloseIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                          Foreground="{StaticResource BlackBrush}"/>
            </Button>
        </Grid>

        <!-- Divider -->
        <controls:DividerControl Grid.Row="1"
                                 DividerBrush="{StaticResource LighterGrayBrush}"
                                 Margin="-36,0,-36,0"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" Spacing="22" Margin="0,20,0,0">
            <!-- Server Address -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.ServerAddressLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="{StaticResource LabelFontSize}"
                           Foreground="{StaticResource BlackBrush}"/>
                <TextBox x:Name="ServerAddressBox"
                         PlaceholderText="{x:Bind ViewModel.ServerAddressPlaceholderDisplay, Mode=OneWay}"
                         Text="{x:Bind ViewModel.ServerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         CornerRadius="8" 
                         FontSize="{StaticResource ValueFontSize}"
                         Padding="16,12"
                         BorderThickness="1"
                         BorderBrush="{StaticResource LightGrayBrush}">
                    <TextBox.Resources>
                        <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- API Key -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.ApiKeyLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="{StaticResource LabelFontSize}"
                           Foreground="{StaticResource BlackBrush}"/>
                <PasswordBox x:Name="ApiKeyBox"
                             PlaceholderText="{x:Bind ViewModel.ApiKeyPlaceholderDisplay, Mode=OneWay}"
                             PasswordChanged="ApiKeyBox_PasswordChanged"
                             CornerRadius="8" 
                             FontSize="{StaticResource ValueFontSize}"
                             Padding="16,12"
                             BorderThickness="1"
                             PasswordRevealMode="Hidden"
                             BorderBrush="{StaticResource LightGrayBrush}">
                    <PasswordBox.Resources>
                        <Visibility x:Key="PasswordRevealButtonVisibility">Collapsed</Visibility>
                        <Visibility x:Key="PasswordRevealButtonCollapsedVisibility">Collapsed</Visibility>
                        <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>

            <!-- Divider -->
            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}"/>

            <!-- Footer -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{x:Bind ViewModel.RememberMe, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Style="{StaticResource OrangeCheckBoxStyle}">
                    <TextBlock Text="{x:Bind ViewModel.RememberMeLabelDisplay, Mode=OneWay}"
                               FontSize="{StaticResource FontSizeSmall}"
                               FontWeight="Thin"
                               Foreground="{StaticResource DarkGrayBrush}"
                               TextWrapping="NoWrap"
                               VerticalAlignment="Center"/>
                </CheckBox>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Button x:Name="SaveButton"
                            Command="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotSaving, Mode=OneWay}"
                            CornerRadius="7"
                            Padding="24,10"
                            FontSize="{StaticResource FontSizeMedium}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WhiteBrush}"
                            Background="{StaticResource OrangeFocusBrush}"
                            Width="100"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="PrimaryOrangeDarkBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="PrimaryOrangeDarkerBrush"/>
                            <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="LighterGrayBrush"/>
                            <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="PlaceholderGrayBrush"/>
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.SaveButtonDisplay, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsSaving, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</ContentDialog>
