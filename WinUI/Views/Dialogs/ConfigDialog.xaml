<ContentDialog
    x:Class="WinUI.Views.Dialogs.ConfigDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    Style="{StaticResource StandardFormDialogStyle}">

    <ContentDialog.Resources>
        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
    </ContentDialog.Resources>

    <dialogControls:DialogShell Size="Standard"
                                Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.ServerAddressLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <TextBox x:Name="ServerAddressBox"
                             PlaceholderText="{x:Bind ViewModel.ServerAddressPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.ServerAddressPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.ServerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogFormTextBoxStyle}" />
                </StackPanel>

                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.PortLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <TextBox x:Name="PortBox"
                             PlaceholderText="{x:Bind ViewModel.PortPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.PortPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             InputScope="Number"
                             MaxLength="5"
                             Style="{StaticResource DialogFormTextBoxStyle}" />
                </StackPanel>

                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.ApiKeyLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <PasswordBox x:Name="ApiKeyBox"
                                 PlaceholderText="{x:Bind ViewModel.ApiKeyPlaceholderText, Mode=OneWay}"
                                 ToolTipService.ToolTip="{x:Bind ViewModel.ApiKeyPlaceholderText, Mode=OneWay}"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"
                                 Style="{StaticResource DialogFormPasswordBoxStyle}" />
                </StackPanel>
            </StackPanel>
        </dialogControls:DialogShell.BodyContent>

        <dialogControls:DialogShell.FooterContent>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          IsChecked="{x:Bind ViewModel.RememberMe, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Style="{StaticResource OrangeCheckBoxStyle}">
                    <TextBlock Text="{x:Bind ViewModel.RememberMeLabelText, Mode=OneWay}"
                               FontSize="{StaticResource FontSizeSmall}"
                               FontWeight="Thin"
                               Foreground="{StaticResource DarkGrayBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center"
                               ToolTipService.ToolTip="{x:Bind ViewModel.RememberMeLabelText, Mode=OneWay}" />
                </CheckBox>

                <Grid Grid.Column="1"
                      MinWidth="120"
                      VerticalAlignment="Center">
                    <Button x:Name="SaveButton"
                            Command="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotSaving, Mode=OneWay}"
                            Style="{StaticResource DialogCompactPrimaryButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.SaveButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.SaveButtonText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsSaving, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </dialogControls:DialogShell.FooterContent>
    </dialogControls:DialogShell>
</ContentDialog>
