<ContentDialog
    x:Class="WinUI.Views.Dialogs.ForgotPasswordDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    CornerRadius="12"
    Background="{StaticResource WhiteBrush}"
    Width="1200"
    Height="Auto"
    HorizontalAlignment="Center"
    Padding="20">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <PathIcon Grid.Column="0"
                      Width="22"
                      Height="22"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                      Foreground="{StaticResource BlackBrush}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                       FontSize="{StaticResource DialogHeaderFontSize}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BlackBrush}"/>
            <Button Grid.Column="2"
                    Width="32"
                    Height="32"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="0"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AntiqueWhiteBrush"/>
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="LighterGrayBrush"/>
                </Button.Resources>
                <PathIcon Width="14"
                          Height="14"
                          Data="{x:Bind CloseIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                          Foreground="{StaticResource BlackBrush}"/>
            </Button>
        </Grid>

        <controls:DividerControl Grid.Row="1"
                                 DividerBrush="{StaticResource LighterGrayBrush}"
                                 Margin="-36,0,-36,0"/>

        <StackPanel Grid.Row="2" Spacing="22" Margin="0,20,0,0">
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.EmailLabelText, Mode=OneWay}"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource LabelFontSize}"
                           Foreground="{StaticResource BlackBrush}"/>
                <TextBox x:Name="RecoveryEmailBox"
                         PlaceholderText="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                         Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         CornerRadius="8"
                         FontSize="{StaticResource ValueFontSize}"
                         Padding="16,12"
                         BorderThickness="1"
                         BorderBrush="{StaticResource LightGrayBrush}">
                    <TextBox.Resources>
                        <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                       Foreground="{StaticResource ErrorRedBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold"/>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}"/>

            <Grid Margin="0,8,0,0" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Button x:Name="BackButton"
                            Command="{x:Bind ViewModel.BackCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                            CornerRadius="7"
                            Padding="10"
                            FontSize="{StaticResource FontSizeMedium}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BlackBrush}"
                            Background="{StaticResource TransparentBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource LightGrayBrush}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="PrimaryOrangeDarkBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="PrimaryOrangeDarkerBrush"/>
                            <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="WhiteBrush"/>
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.BackButtonText, Mode=OneWay}"/>
                    </Button>
                </Grid>

                <Grid Grid.Column="1">
                    <Button x:Name="SendOtpButton"
                            Command="{x:Bind ViewModel.SendOtpCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                            CornerRadius="7"
                            Padding="10"
                            FontSize="{StaticResource FontSizeMedium}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WhiteBrush}"
                            Background="{StaticResource OrangeFocusBrush}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="PrimaryOrangeDarkBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="PrimaryOrangeDarkerBrush"/>
                            <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="LighterGrayBrush"/>
                            <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="MediumDarkGrayBrush"/>
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.SendOtpButtonText, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsSubmitting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</ContentDialog>
