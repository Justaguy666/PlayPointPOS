<ContentDialog
    x:Class="WinUI.Views.Dialogs.ForgotPasswordDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    Style="{StaticResource StandardFormDialogStyle}">

    <ContentDialog.Resources>
        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
    </ContentDialog.Resources>

    <dialogControls:DialogShell Size="Standard"
                                Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.EmailLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <TextBox x:Name="RecoveryEmailBox"
                             PlaceholderText="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogFormTextBoxStyle}" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </dialogControls:DialogShell.BodyContent>

        <dialogControls:DialogShell.FooterContent>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="BackButton"
                        Command="{x:Bind ViewModel.BackCommand, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsNotSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                        Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.BackButtonText, Mode=OneWay}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                    </Button.Resources>
                    <TextBlock Text="{x:Bind ViewModel.BackButtonText, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </Button>

                <Grid Grid.Column="1">
                    <Button x:Name="SendOtpButton"
                            Command="{x:Bind ViewModel.SendOtpCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                            Style="{StaticResource DialogPrimaryFooterButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.SendOtpButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.SendOtpButtonText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsSubmitting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsSubmitting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </dialogControls:DialogShell.FooterContent>
    </dialogControls:DialogShell>
</ContentDialog>
