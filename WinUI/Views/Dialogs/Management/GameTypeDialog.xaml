<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.GameTypeDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.Dialogs.Management"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=vm:GameTypeDialogViewModel, IsDesignTimeCreatable=False}"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid x:Name="RootGrid"
          Style="{StaticResource DialogFormRootGridStyle}"
          MaxWidth="620">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DialogHeaderContainerStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <PathIcon Grid.Column="0"
                      Style="{StaticResource DialogHeaderIconStyle}"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" 
					  VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource DialogHeaderTitleTextStyle}"
                       Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                </Button.Resources>
                <FontIcon Glyph="&#xE711;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="{StaticResource FontSizeSmall}"
                          Foreground="{StaticResource BlackBrush}" />
            </Button>
        </Grid>

        <controls:DividerControl Grid.Row="1"
                                 Style="{StaticResource DialogHeaderDividerStyle}" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      Margin="0,0,-16,0"
                      Padding="0,0,16,20"
                      MaxHeight="400">
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0"
                             PlaceholderText="{x:Bind ViewModel.NamePlaceholderText, Mode=OneWay}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             Text="{x:Bind ViewModel.NewGameTypeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                             
                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{x:Bind ViewModel.AddGameTypeCommand, Mode=OneWay}"
                            IsEnabled="{x:Bind ViewModel.CanAddGameType, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.AddButtonText, Mode=OneWay}" />
                    </Button>
                </Grid>

                <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.GameTypes, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinColumnSpacing="8"
                                           MinRowSpacing="8"
                                           ItemsJustification="Start"
                                           Orientation="Horizontal"
                                           MinItemWidth="132" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameTypeItemViewModel">
                            <Grid DoubleTapped="OnGameTypeDoubleTapped"
                                  HorizontalAlignment="Left"
                                  Background="Transparent">
                                <Border Background="{StaticResource WhiteBrush}"
                                        BorderBrush="{StaticResource LightGrayBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        HorizontalAlignment="Left"
                                        Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToInvisible}}">
                                    <Grid ColumnSpacing="6"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Name, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BlackBrush}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Button Grid.Column="1"
                                                Command="{x:Bind DeleteCommand}"
                                                Width="18"
                                                Height="18"
                                                MinWidth="18"
                                                MinHeight="18"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Foreground="{StaticResource BlackBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="×"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BlackBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                      ColumnSpacing="8"
                                      MinWidth="300">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{x:Bind EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DialogFormTextBoxStyle}"
                                             MinHeight="40" />

                                    <Button Grid.Column="1"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Command="{x:Bind CommitEditCommand}"
                                            Height="40"
                                            Padding="12,0">
                                        <TextBlock Text="✓" />
                                    </Button>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Command="{x:Bind CancelEditCommand}"
                                            Height="40"
                                            Padding="12,0">
                                        <TextBlock Text="✕" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
