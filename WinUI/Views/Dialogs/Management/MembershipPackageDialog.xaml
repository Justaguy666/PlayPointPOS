<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.MembershipPackageDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.Dialogs.Management"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=vm:MembershipPackageDialogViewModel, IsDesignTimeCreatable=False}"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid x:Name="RootGrid"
          Style="{StaticResource DialogFormRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DialogHeaderContainerStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <PathIcon Grid.Column="0"
                      Style="{StaticResource DialogHeaderIconStyle}"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource DialogHeaderTitleTextStyle}"
                       Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                </Button.Resources>
                <FontIcon Glyph="&#xE711;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="14"
                          Foreground="{StaticResource DarkGrayBrush}" />
            </Button>
        </Grid>

        <controls:DividerControl Grid.Row="1"
                                 Style="{StaticResource DialogHeaderDividerStyle}" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      Margin="0,0,-16,0"
                      Padding="0,0,16,20"
                      MaxHeight="520">
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <Grid ColumnSpacing="12"
                      RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Grid.Row="0"
                             MinWidth="160"
                             PlaceholderText="{x:Bind ViewModel.NamePlaceholderText, Mode=OneWay}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             Text="{x:Bind ViewModel.NewMembershipRankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="1"
                             Grid.Row="0"
                             MinWidth="160"
                             PlaceholderText="{x:Bind ViewModel.MinSpentPlaceholderText, Mode=OneWay}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             Text="{x:Bind ViewModel.NewMinSpentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="0"
                             Grid.Row="1"
                             MinWidth="160"
                             PlaceholderText="{x:Bind ViewModel.DiscountPlaceholderText, Mode=OneWay}"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             Text="{x:Bind ViewModel.NewDiscountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                            Height="48"
                            MinWidth="160"
                            Padding="12,0"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="Màu gói">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{x:Bind ViewModel.PaintIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                      Foreground="{x:Bind ViewModel.NewMembershipRankBrush, Mode=OneWay}" />
                            <TextBlock Text="Màu gói" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Padding="8">
                                    <ColorPicker Color="{x:Bind ViewModel.NewMembershipRankColor, Mode=TwoWay}"
                                                 IsAlphaEnabled="False"
                                                 IsAlphaSliderVisible="False"
                                                 IsColorChannelTextInputVisible="False"
                                                 IsColorSliderVisible="False"
                                                 IsHexInputVisible="False"
                                                 IsMoreButtonVisible="False"
                                                 IsColorSpectrumVisible="True"
                                                 Width="220"
                                                 Height="220" />
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{x:Bind ViewModel.AddMembershipRankCommand, Mode=OneWay}"
                            IsEnabled="{x:Bind ViewModel.CanAddMembershipRank, Mode=OneWay}"
                            Height="48"
                            MinWidth="0"
                            Padding="18,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.AddButtonText, Mode=OneWay}" />
                    </Button>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.MembershipRanks, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="10" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:MembershipPackageItemViewModel">
                            <Grid DoubleTapped="OnMembershipPackageDoubleTapped">
                                <Border Background="{StaticResource WhiteBrush}"
                                        BorderBrush="{StaticResource LighterGrayBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="20,18"
                                        Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToInvisible}}">
                                    <Grid ColumnSpacing="16"
                                          RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                   Grid.Row="0"
                                                   Orientation="Horizontal"
                                                   Spacing="8"
                                                   VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                       Style="{StaticResource MemberCardNameTextStyle}"
                                                       MaxLines="1" />
                                            <Ellipse Width="12"
                                                     Height="12"
                                                     VerticalAlignment="Center"
                                                     Fill="{x:Bind RankColorBrush, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionButtonStyle}"
                                                    Command="{x:Bind BeginEditCommand}"
                                                    ToolTipService.ToolTip="Edit">
                                                <Button.Resources>
                                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                                                </Button.Resources>
                                                <PathIcon Width="16"
                                                          Height="16"
                                                          Data="{x:Bind EditIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                                          Foreground="{StaticResource WhiteBrush}" />
                                            </Button>

                                            <Button Style="{StaticResource CardDangerButtonStyle}"
                                                    Command="{x:Bind DeleteCommand}">
                                                <Button.Resources>
                                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                                                </Button.Resources>
                                                <PathIcon Width="16"
                                                          Height="16"
                                                          Data="{x:Bind DeleteIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                                          Foreground="{StaticResource WhiteBrush}" />
                                            </Button>
                                        </StackPanel>

                                        <Grid Grid.Column="0"
                                              Grid.Row="1"
                                              Grid.ColumnSpan="2"
                                              Margin="0,8,0,0"
                                              ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Vertical"
                                                        Grid.Column="0"
                                                        Spacing="2">
                                                <TextBlock Text="{x:Bind MinSpentLabelText, Mode=OneWay}"
                                                           Style="{StaticResource MemberCardMetaLabelTextStyle}" />
                                                <TextBlock Text="{x:Bind MinSpentText, Mode=OneWay}"
                                                           Style="{StaticResource MemberCardMetaValueTextStyle}" />
                                            </StackPanel>

                                            <StackPanel Orientation="Vertical"
                                                        Grid.Column="1"
                                                        Spacing="2">
                                                <TextBlock Text="{x:Bind DiscountLabelText, Mode=OneWay}"
                                                           Style="{StaticResource MemberCardMetaLabelTextStyle}" />
                                                <TextBlock Text="{x:Bind DiscountText, Mode=OneWay}"
                                                           Style="{StaticResource MemberCardMetaValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                      ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{x:Bind EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DialogFormTextBoxStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{x:Bind EditMinSpentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DialogFormTextBoxStyle}" />
                                    <TextBox Grid.Column="2"
                                             Text="{x:Bind EditDiscountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DialogFormTextBoxStyle}" />

                                    <Button Grid.Column="3"
                                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                                            Height="48"
                                            MinWidth="160"
                                            Padding="12,0"
                                            ToolTipService.ToolTip="Màu gói">
                                        <Button.Resources>
                                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <PathIcon Width="16"
                                                      Height="16"
                                                      Data="{x:Bind PaintIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                                      Foreground="{x:Bind EditColorBrush, Mode=OneWay}" />
                                            <TextBlock Text="Màu gói" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <Border Padding="8">
                                                    <ColorPicker Color="{x:Bind EditColor, Mode=TwoWay}"
                                                                 IsAlphaEnabled="False"
                                                                 IsAlphaSliderVisible="False"
                                                                 IsColorChannelTextInputVisible="False"
                                                                 IsColorSliderVisible="False"
                                                                 IsHexInputVisible="False"
                                                                 IsMoreButtonVisible="False"
                                                                 IsColorSpectrumVisible="True"
                                                                 Width="220"
                                                                 Height="220" />
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Command="{x:Bind CommitEditCommand}"
                                            Height="48"
                                            Padding="16,0">
                                        <TextBlock Text="✓"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                    </Button>

                                    <Button Grid.Column="5"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Command="{x:Bind CancelEditCommand}"
                                            Height="48"
                                            Padding="16,0">
                                        <TextBlock Text="✕"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
