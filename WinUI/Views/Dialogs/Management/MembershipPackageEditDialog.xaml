<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.MembershipPackageEditDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid Style="{StaticResource DialogFormRootGridStyle}"
          MaxWidth="620">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DialogHeaderContainerStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <PathIcon Grid.Column="0"
                      Style="{StaticResource DialogHeaderIconStyle}"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource DialogHeaderTitleTextStyle}"
                       Text="{x:Bind ViewModel.TitleText, Mode=OneWay}" />
            <Button Grid.Column="2"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                </Button.Resources>
                <FontIcon Glyph="&#xE711;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="{StaticResource FontSizeSmall}"
                          Foreground="{StaticResource DarkGrayBrush}" />
            </Button>
        </Grid>

        <controls:DividerControl Grid.Row="1"
                                 Style="{StaticResource DialogHeaderDividerStyle}" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      Margin="0,0,-16,0"
                      Padding="0,0,16,20">
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <Grid ColumnSpacing="12"
                      RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Grid.Row="0"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.NamePlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="1"
                             Grid.Row="0"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.MinSpentPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditMinSpentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="0"
                             Grid.Row="1"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.DiscountPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditDiscountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                            Height="48"
                            MinWidth="160"
                            Padding="12,0"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="{x:Bind ViewModel.ColorButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{x:Bind ViewModel.PaintIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                      Foreground="{x:Bind ViewModel.EditColorBrush, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.ColorButtonText, Mode=OneWay}" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Padding="8">
                                    <ColorPicker Color="{x:Bind ViewModel.EditColor, Mode=TwoWay}"
                                                 IsAlphaEnabled="False"
                                                 IsAlphaSliderVisible="False"
                                                 IsColorChannelTextInputVisible="False"
                                                 IsColorSliderVisible="False"
                                                 IsHexInputVisible="False"
                                                 IsMoreButtonVisible="False"
                                                 IsColorSpectrumVisible="True"
                                                 Width="220"
                                                 Height="220" />
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                            Command="{x:Bind ViewModel.CancelCommand, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.CancelButtonText, Mode=OneWay}" />
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource DialogPrimaryFooterButtonStyle}"
                            Command="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                            IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.SaveButtonText, Mode=OneWay}" />
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
