<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.MembershipPackageEditDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    xmlns:panels="using:WinUI.Views.Panels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <dialogControls:DialogShell Size="Standard"
                                MaxBodyHeight="420"
                                Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <panels:ResponsiveFormPanel ColumnSpacing="12"
                                            RowSpacing="10"
                                            MinColumnWidth="180">
                    <TextBox Grid.Column="0"
                             Grid.Row="0"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.NamePlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.NamePlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="1"
                             Grid.Row="0"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.MinSpentPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.MinSpentPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditMinSpentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="0"
                             Grid.Row="1"
                             MinWidth="160"
                             Style="{StaticResource DialogFormTextBoxStyle}"
                             PlaceholderText="{x:Bind ViewModel.DiscountPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.DiscountPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.EditDiscountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                            Height="48"
                            MinWidth="160"
                            Padding="12,0"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="{x:Bind ViewModel.ColorButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{x:Bind ViewModel.PaintIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                                      Foreground="{x:Bind ViewModel.EditColorBrush, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.ColorButtonText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Padding="8">
                                    <ColorPicker Color="{x:Bind ViewModel.EditColor, Mode=TwoWay}"
                                                 IsAlphaEnabled="False"
                                                 IsAlphaSliderVisible="False"
                                                 IsColorChannelTextInputVisible="False"
                                                 IsColorSliderVisible="False"
                                                 IsHexInputVisible="False"
                                                 IsMoreButtonVisible="False"
                                                 IsColorSpectrumVisible="True"
                                                 Width="220"
                                                 Height="220" />
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </panels:ResponsiveFormPanel>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </dialogControls:DialogShell.BodyContent>

        <dialogControls:DialogShell.FooterContent>
            <dialogControls:DialogFooterActions SecondaryText="{x:Bind ViewModel.CancelButtonText, Mode=OneWay}"
                                                 SecondaryCommand="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
                                                 PrimaryText="{x:Bind ViewModel.SaveButtonText, Mode=OneWay}"
                                                 PrimaryCommand="{x:Bind ViewModel.SaveCommand, Mode=OneWay}"
                                                 IsPrimaryEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}" />
        </dialogControls:DialogShell.FooterContent>
    </dialogControls:DialogShell>
</ContentDialog>
