<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.PaymentDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    xmlns:vm="using:WinUI.ViewModels.Dialogs.Management"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=vm:PaymentViewModel, IsDesignTimeCreatable=False}"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <dialogControls:DialogShell Size="Standard"
                                MaxBodyHeight="520"
                                Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind ViewModel.CancelCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
        <StackPanel Style="{StaticResource DialogFormContentPanelStyle}"
                Margin="0,12,12,16"
                Spacing="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.AreaLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.AreaValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DurationLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.DurationValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.AreaFeeLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.AreaFeeValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogMoneyValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.ProductFeeLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.ProductFeeValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogMoneyValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.GameFeeLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.GameFeeValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogMoneyValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DepositLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.DepositValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogMoneyValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DiscountLabelText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogRowLabelTextStyle}" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.DiscountValueText, Mode=OneWay}"
                           Style="{StaticResource PaymentDialogMoneyValueTextStyle}" />
            </Grid>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <Border Background="{StaticResource OrangePeachLightBrush}"
                    CornerRadius="16"
                    Padding="18"
                    Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.TotalLabelText, Mode=OneWay}"
                               Style="{StaticResource PaymentDialogTotalLabelTextStyle}" />

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.TotalValueText, Mode=OneWay}"
                               Style="{StaticResource PaymentDialogTotalValueTextStyle}" />
                </Grid>
            </Border>

            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}" />

            <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                <TextBlock Text="{Binding PaymentMethodLabelText}"
                           Style="{StaticResource DialogFormLabelTextStyle}" />
                <ComboBox MinHeight="48"
                          ItemsSource="{Binding PaymentMethodOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedPaymentMethodValue, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          ToolTipService.ToolTip="{Binding PaymentMethodLabelText}" />
            </StackPanel>
        </StackPanel>
        </dialogControls:DialogShell.BodyContent>

        <dialogControls:DialogShell.FooterContent>
            <dialogControls:DialogFooterActions ShowSecondaryButton="False"
                                                 UseSuccessPrimaryStyle="True"
                                                 PrimaryText="{x:Bind ViewModel.ConfirmButtonText, Mode=OneWay}"
                                                 PrimaryCommand="{x:Bind ViewModel.ConfirmCommand, Mode=OneWay}" />
        </dialogControls:DialogShell.FooterContent>
    </dialogControls:DialogShell>
</ContentDialog>
