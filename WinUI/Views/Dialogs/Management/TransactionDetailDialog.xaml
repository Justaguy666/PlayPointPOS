<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.TransactionDetailDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    xmlns:viewmodels="using:WinUI.ViewModels.Dialogs.Management"
    d:DataContext="{d:DesignInstance Type=viewmodels:TransactionDetailDialogViewModel, IsDesignTimeCreatable=False}"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <dialogControls:DialogShell Size="Standard"
                                MaxBodyHeight="520"
                                Title="{x:Bind ViewModel.Title, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind CloseCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
            <StackPanel Spacing="0"
                        Margin="0,20,0,0">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding ServiceDetailHeaderText}"
                               FontSize="{StaticResource FontSizeExtraSmall}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               CharacterSpacing="60" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AmountHeaderText}"
                               FontSize="{StaticResource FontSizeExtraSmall}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               CharacterSpacing="60" />
                </Grid>

                <Border Height="1"
                        Background="{StaticResource LighterGrayBrush}"
                        Margin="0,0,0,4" />

                <ItemsRepeater ItemsSource="{Binding Lines}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:TransactionLineDisplayModel">
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="2">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DarkSlateGrayBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               ToolTipService.ToolTip="{x:Bind Name}" />
                                    <TextBlock Text="{x:Bind Description}"
                                               FontSize="{StaticResource FontSizeExtraSmall}"
                                               Foreground="{StaticResource SecondaryGrayBrush}"
                                               FontStyle="Italic"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               ToolTipService.ToolTip="{x:Bind Description}" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind AmountText}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{StaticResource DarkSlateGrayBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Grid Padding="0,12"
                      Visibility="{Binding HasDepositRefund, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding DepositRefundText}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DepositRefundAmountText}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource DarkSlateGrayBrush}"
                               HorizontalAlignment="Right" />
                </Grid>

                <Grid Padding="0,12"
                      Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding DiscountText}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiscountAmountText}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource DarkSlateGrayBrush}"
                               HorizontalAlignment="Right" />
                </Grid>

                <Border Height="1"
                        Background="{StaticResource LighterGrayBrush}"
                        Margin="0,4,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding TotalLabelText}"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalAmountText}"
                               FontSize="{StaticResource FontSizeLarge}"
                               FontWeight="Bold"
                               Foreground="{StaticResource OrangeFocusBrush}"
                               HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </dialogControls:DialogShell.BodyContent>
    </dialogControls:DialogShell>
</ContentDialog>
