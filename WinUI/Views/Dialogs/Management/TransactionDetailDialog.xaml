<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WinUI.Views.Dialogs.Management.TransactionDetailDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:viewmodels="using:WinUI.ViewModels.Dialogs.Management"
    d:DataContext="{d:DesignInstance Type=viewmodels:TransactionDetailDialogViewModel, IsDesignTimeCreatable=False}"
    Style="{StaticResource StandardFormDialogStyle}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource DialogFormRootGridStyle}"
          MinWidth="480"
          MaxWidth="620">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DialogHeaderContainerStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <PathIcon Grid.Column="0"
                      Style="{StaticResource DialogHeaderIconStyle}"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource DialogHeaderTitleTextStyle}"
                       Text="{Binding Title}" />
            <Button Grid.Column="2"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    Click="HandleCloseButtonClick"
                    ToolTipService.ToolTip="{Binding CloseTooltipText}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                </Button.Resources>
                <PathIcon Width="14"
                          Height="14"
                          Foreground="{StaticResource BlackBrush}"
                          Data="{x:Bind CloseIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
            </Button>
        </Grid>

        <controls:DividerControl Grid.Row="1"
                                 Style="{StaticResource DialogHeaderDividerStyle}" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      Margin="0,0,-16,0"
                      Padding="0,0,16,16">
            <StackPanel Spacing="0"
                        Margin="0,20,0,0">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding ServiceDetailHeaderText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               CharacterSpacing="60" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AmountHeaderText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               CharacterSpacing="60" />
                </Grid>

                <Border Height="1"
                        Background="{StaticResource LighterGrayBrush}"
                        Margin="0,0,0,4" />

                <ItemsRepeater ItemsSource="{Binding Lines}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:TransactionLineDisplayModel">
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="2">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                                    <TextBlock Text="{x:Bind Description}"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryGrayBrush}"
                                               FontStyle="Italic" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind AmountText}"
                                           FontSize="14"
                                           Foreground="{StaticResource DarkSlateGrayBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Grid Padding="0,12"
                      Visibility="{Binding HasDepositRefund, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding DepositRefundText}"
                               FontSize="14"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DepositRefundAmountText}"
                               FontSize="14"
                               Foreground="{StaticResource DarkSlateGrayBrush}"
                               HorizontalAlignment="Right" />
                </Grid>

                <Grid Padding="0,12"
                      Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding DiscountText}"
                               FontSize="14"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DiscountAmountText}"
                               FontSize="14"
                               Foreground="{StaticResource DarkSlateGrayBrush}"
                               HorizontalAlignment="Right" />
                </Grid>

                <Border Height="1"
                        Background="{StaticResource LighterGrayBrush}"
                        Margin="0,4,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding TotalLabelText}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkSlateGrayBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalAmountText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource OrangeFocusBrush}"
                               HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
