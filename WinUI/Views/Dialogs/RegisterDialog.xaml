<ContentDialog
    x:Class="WinUI.Views.Dialogs.RegisterDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="14"
    Background="#FFFFFF"
    Width="1200"
    Height="Auto"
    HorizontalAlignment="Center"
    Padding="36">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0"
                      Glyph="&#xE8FA;"
                      FontSize="22"
                      FontWeight="Bold"
                      Margin="0,0,12,0"
                      Foreground="#1F1F1F"
                      VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.TitleDisplay, Mode=OneWay}"
                       FontSize="19"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="#1F1F1F"/>
            <Button Grid.Column="2"
                    Width="32" Height="32"
                    Click="OnCloseButtonClick"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="0"
                    ToolTipService.ToolTip="Đóng">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5E7EB"/>
                </Button.Resources>
                <FontIcon Glyph="&#xE8BB;" FontSize="14" Foreground="#1F1F1F"/>
            </Button>
        </Grid>

        <!-- Divider -->
        <Rectangle Grid.Row="1" 
                   Height="1" 
                   Fill="#E5E7EB" 
                   Margin="-36,0,-36,0"
                   VerticalAlignment="Center"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" Spacing="22" Margin="0,20,0,0">
            <!-- Email -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.EmailLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           Foreground="#1F1F1F"/>
                <TextBox x:Name="EmailBox"
                         PlaceholderText="{x:Bind ViewModel.EmailPlaceholderDisplay, Mode=OneWay}"
                         Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderForeground="Gray"
                         CornerRadius="8" 
                         FontSize="15"
                         Padding="16,12"
                         BorderThickness="1"
                         BorderBrush="#D8D8D8">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                        <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF7A30"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#B3B3B3"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="Gray"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="Gray"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="Gray"/>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Password -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.PasswordLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           Foreground="#1F1F1F"/>
                <PasswordBox x:Name="PasswordBox"
                             PlaceholderText="{x:Bind ViewModel.PasswordPlaceholderDisplay, Mode=OneWay}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             CornerRadius="8" 
                             FontSize="15"
                             Padding="16,12"
                             BorderThickness="1"
                             PasswordRevealMode="Hidden"
                             BorderBrush="#D8D8D8">
                    <PasswordBox.Resources>
                        <Visibility x:Key="PasswordRevealButtonVisibility">Collapsed</Visibility>
                        <Visibility x:Key="PasswordRevealButtonCollapsedVisibility">Collapsed</Visibility>
                        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                        <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF7A30"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#B3B3B3"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>

            <!-- Confirm Password -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.ConfirmPasswordLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           Foreground="#1F1F1F"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             PlaceholderText="{x:Bind ViewModel.ConfirmPasswordPlaceholderDisplay, Mode=OneWay}"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                             CornerRadius="8" 
                             FontSize="15"
                             Padding="16,12"
                             BorderThickness="1"
                             PasswordRevealMode="Hidden"
                             BorderBrush="#D8D8D8">
                    <PasswordBox.Resources>
                        <Visibility x:Key="PasswordRevealButtonVisibility">Collapsed</Visibility>
                        <Visibility x:Key="PasswordRevealButtonCollapsedVisibility">Collapsed</Visibility>
                        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                        <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF7A30"/>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#B3B3B3"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#888888"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#888888"/>
                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#888888"/>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>

            <!-- OTP -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.OTPLabelDisplay, Mode=OneWay}" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           Foreground="#1F1F1F"/>
                <Grid>
                    <TextBox x:Name="OTPBox"
                             PlaceholderText="{x:Bind ViewModel.OTPPlaceholderDisplay, Mode=OneWay}"
                             Text="{x:Bind ViewModel.OTP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderForeground="Gray"
                             CornerRadius="8" 
                             FontSize="15"
                             Padding="16,12,50,12"
                             BorderThickness="1"
                             BorderBrush="#D8D8D8">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                            <SolidColorBrush x:Key="TextControlForeground" Color="Black"/>
                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="Black"/>
                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="Black"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF7A30"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#B3B3B3"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="Gray"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="Gray"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="Gray"/>
                        </TextBox.Resources>
                    </TextBox>
                    <Border HorizontalAlignment="Right" 
                            BorderThickness="1,0,0,0" 
                            BorderBrush="#D8D8D8" 
                            Width="50" 
                            Margin="0,1,1,1"
                            CornerRadius="0,7,7,0">
                        <Button x:Name="SendOTPButton"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                CornerRadius="0,7,7,0"
                                Padding="0">
                            <FontIcon Glyph="&#xE724;" FontSize="18" Foreground="#000000"/>
                        </Button>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
                       Foreground="#DC2626"
                       FontSize="14"
                       FontWeight="SemiBold"/>

            <!-- Divider -->
            <Rectangle Height="1" 
                       Fill="#E5E7EB" 
                       Margin="0,8,0,8"/>

            <!-- Footer -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Button x:Name="ResetButton"
                            Click="ResetButton_Click"
                            Command="{x:Bind ViewModel.ResetCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotResetting, Mode=OneWay}"
                            CornerRadius="7"
                            Padding="0,10"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#1F1F1F"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="#D8D8D8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F3F4F6"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5E7EB"/>
                        </Button.Resources>
                        
                        <TextBlock Text="{x:Bind ViewModel.ResetButtonDisplay, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsResetting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsResetting, Mode=OneWay}"
                                  Foreground="#FF7A30"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Column="2">
                    <Button x:Name="RegisterButton"
                            Command="{x:Bind ViewModel.RegisterCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotRegistering, Mode=OneWay}"
                            CornerRadius="7"
                            Padding="0,10"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#FF7A30"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">

                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E55A1F"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC481A"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>

                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#E5E7EB"/>
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#9CA3AF"/>
                        </Button.Resources>

                        <TextBlock Text="{x:Bind ViewModel.RegisterButtonDisplay, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsRegistering, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsRegistering, Mode=OneWay}"
                                  Foreground="#FF7A30"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</ContentDialog>
