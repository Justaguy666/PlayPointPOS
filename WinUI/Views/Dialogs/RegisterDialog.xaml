<ContentDialog
    x:Class="WinUI.Views.Dialogs.RegisterDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogControls="using:WinUI.Views.UserControls.Dialogs"
    xmlns:helpers="using:WinUI.Helpers"
    Style="{StaticResource StandardFormDialogStyle}">

    <ContentDialog.Resources>
        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
    </ContentDialog.Resources>

    <dialogControls:DialogShell Size="Standard"
                                MaxBodyHeight="460"
                                Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                                IconState="{x:Bind HeaderIconState, Mode=OneWay}"
                                CloseCommand="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                                CloseTooltipText="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
        <dialogControls:DialogShell.BodyContent>
            <StackPanel Style="{StaticResource DialogFormContentPanelStyle}">
                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.EmailLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <TextBox x:Name="EmailBox"
                             PlaceholderText="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogFormTextBoxStyle}" />
                </StackPanel>

                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.PasswordLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="{x:Bind ViewModel.PasswordPlaceholderText, Mode=OneWay}"
                                 ToolTipService.ToolTip="{x:Bind ViewModel.PasswordPlaceholderText, Mode=OneWay}"
                                 helpers:PasswordBoxBindingHelper.BindPassword="True"
                                 helpers:PasswordBoxBindingHelper.BoundPassword="{Binding Password, Mode=TwoWay}"
                                 Style="{StaticResource DialogFormPasswordBoxStyle}" />
                </StackPanel>

                <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                    <TextBlock Text="{x:Bind ViewModel.ConfirmPasswordLabelText, Mode=OneWay}"
                               Style="{StaticResource DialogFormLabelTextStyle}" />
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 PlaceholderText="{x:Bind ViewModel.ConfirmPasswordPlaceholderText, Mode=OneWay}"
                                 ToolTipService.ToolTip="{x:Bind ViewModel.ConfirmPasswordPlaceholderText, Mode=OneWay}"
                                 helpers:PasswordBoxBindingHelper.BindPassword="True"
                                 helpers:PasswordBoxBindingHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                 Style="{StaticResource DialogFormPasswordBoxStyle}" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </dialogControls:DialogShell.BodyContent>

        <dialogControls:DialogShell.FooterContent>
            <Grid ColumnSpacing="16"
                  MinHeight="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Button x:Name="ResetButton"
                            Command="{x:Bind ViewModel.ResetCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotResetting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.ResetButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.ResetButtonText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsResetting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsResetting, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Column="1">
                    <Button x:Name="RegisterButton"
                            Command="{x:Bind ViewModel.RegisterCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotRegistering, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                            Style="{StaticResource DialogPrimaryFooterButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.RegisterButtonText, Mode=OneWay}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <TextBlock Text="{x:Bind ViewModel.RegisterButtonText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsRegistering, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsRegistering, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </dialogControls:DialogShell.FooterContent>
    </dialogControls:DialogShell>
</ContentDialog>
