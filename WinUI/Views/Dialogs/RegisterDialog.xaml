<ContentDialog
    x:Class="WinUI.Views.Dialogs.RegisterDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    Style="{StaticResource StandardFormDialogStyle}">

    <ContentDialog.Resources>
        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
    </ContentDialog.Resources>

    <Grid x:Name="RootGrid"
          Style="{StaticResource DialogFormRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Style="{StaticResource DialogHeaderContainerStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <PathIcon Grid.Column="0"
                      Style="{StaticResource DialogHeaderIconStyle}"
                      Data="{x:Bind HeaderIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                      />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource DialogHeaderTitleTextStyle}"
                       Text="{x:Bind ViewModel.TitleText, Mode=OneWay}"
                       />
            <Button Grid.Column="2"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    Command="{x:Bind ViewModel.CloseCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.CloseTooltipText, Mode=OneWay}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                </Button.Resources>
                <PathIcon Width="14"
                          Height="14"
                          Data="{x:Bind CloseIconState, Mode=OneWay, Converter={StaticResource IconConverter}}"
                          Foreground="{StaticResource BlackBrush}"/>
            </Button>
        </Grid>

        <!-- Divider -->
        <controls:DividerControl Grid.Row="1"
                                 Style="{StaticResource DialogHeaderDividerStyle}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2"
                    Style="{StaticResource DialogFormContentPanelStyle}">
            <!-- Email -->
            <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                <TextBlock Text="{x:Bind ViewModel.EmailLabelText, Mode=OneWay}" 
                           Style="{StaticResource DialogFormLabelTextStyle}"/>
                <TextBox x:Name="EmailBox"
                         PlaceholderText="{x:Bind ViewModel.EmailPlaceholderText, Mode=OneWay}"
                         Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DialogFormTextBoxStyle}" />
            </StackPanel>

            <!-- Password -->
            <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                <TextBlock Text="{x:Bind ViewModel.PasswordLabelText, Mode=OneWay}" 
                           Style="{StaticResource DialogFormLabelTextStyle}"/>
                <PasswordBox x:Name="PasswordBox"
                             PlaceholderText="{x:Bind ViewModel.PasswordPlaceholderText, Mode=OneWay}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Style="{StaticResource DialogFormPasswordBoxStyle}" />
            </StackPanel>

            <!-- Confirm Password -->
            <StackPanel Style="{StaticResource DialogFormFieldPanelStyle}">
                <TextBlock Text="{x:Bind ViewModel.ConfirmPasswordLabelText, Mode=OneWay}" 
                           Style="{StaticResource DialogFormLabelTextStyle}"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             PlaceholderText="{x:Bind ViewModel.ConfirmPasswordPlaceholderText, Mode=OneWay}"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                             Style="{StaticResource DialogFormPasswordBoxStyle}" />
            </StackPanel>

            <!-- Error Message -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
                       Foreground="{StaticResource ErrorRedBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold"/>

            <!-- Divider -->
            <controls:DividerControl Style="{StaticResource DialogSectionDividerStyle}"/>

            <!-- Footer -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Button x:Name="ResetButton"
                            Click="ResetButton_Click"
                            Visibility="{x:Bind ViewModel.IsNotResetting, Mode=OneWay}"
                            Style="{StaticResource DialogSecondaryFooterButtonStyle}">
                        
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        
                        <TextBlock Text="{x:Bind ViewModel.ResetButtonText, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsResetting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsResetting, Mode=OneWay}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Column="2">
                    <Button x:Name="RegisterButton"
                            Command="{x:Bind ViewModel.RegisterCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsNotRegistering, Mode=OneWay}"
                            Style="{StaticResource DialogPrimaryFooterButtonStyle}">

                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>

                        <TextBlock Text="{x:Bind ViewModel.RegisterButtonText, Mode=OneWay}"/>
                    </Button>
                    <ProgressRing Width="20"
                                  Height="20"
                                  IsActive="{x:Bind ViewModel.IsRegistering, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsRegistering, Mode=OneWay}"
                                  Foreground="{StaticResource OrangeFocusBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</ContentDialog>
