<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls.Dashboard"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Hidden">
        <Grid RowSpacing="12" ColumnSpacing="12" Padding="24,36"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" RowSpacing="12" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:StatCardControl Grid.Column="0"
                                          Grid.Row="0"
                                          DataContext="{x:Bind ViewModel.TodayRevenueStatCardViewModel, Mode=OneWay}" />

                <controls:StatCardControl Grid.Column="0"
                                          Grid.Row="1"
                                          DataContext="{x:Bind ViewModel.TodayGameSessionStatCardViewModel, Mode=OneWay}" />

                <controls:StatCardControl Grid.Column="1"
                                          Grid.Row="0"
                                          DataContext="{x:Bind ViewModel.TodayCustomerStatCardViewModel, Mode=OneWay}" />

                <controls:StatCardControl Grid.Column="1"
                                          Grid.Row="1"
                                          DataContext="{x:Bind ViewModel.TodayProductStatCardViewModel, Mode=OneWay}" />
            </Grid>

            <controls:ChartCardControl Grid.Row="1"
                                       Grid.Column="0"
                                       DataContext="{x:Bind ViewModel.RevenueChartCardViewModel, Mode=OneWay}" />

            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Spacing="12">
                <controls:TrendingListControl DataContext="{x:Bind ViewModel.TrendingListViewModel, Mode=OneWay}"
                                              x:Uid="TrendingListControl" />

                <controls:QuickStatsControl DataContext="{x:Bind ViewModel.QuickStatsViewModel, Mode=OneWay}" />

                <controls:GoalProgressControl DataContext="{x:Bind ViewModel.GoalProgressViewModel, Mode=OneWay}" />
            </StackPanel>

            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:PopularCardControl Grid.Column="0"
                                             DataContext="{x:Bind ViewModel.TopGamesCardViewModel, Mode=OneWay}" />

                <controls:PopularCardControl Grid.Column="1"
                                             DataContext="{x:Bind ViewModel.TopFoodsCardViewModel, Mode=OneWay}" />

                <controls:PopularCardControl Grid.Column="2"
                                             DataContext="{x:Bind ViewModel.TopDrinksCardViewModel, Mode=OneWay}" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
