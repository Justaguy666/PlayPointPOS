<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.Pages.GameManagementPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:games="using:WinUI.Views.UserControls.Games"
    xmlns:gameViewModels="using:WinUI.ViewModels.UserControls.Games"
    xmlns:management="using:WinUI.Views.UserControls.Management"
    xmlns:vm="using:WinUI.ViewModels.Pages"
    KeyboardAcceleratorPlacementMode="Hidden"
    d:DataContext="{d:DesignInstance Type=vm:GameManagementPageViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <management:ManagementPageShell>
        <management:ManagementPageShell.ToolbarContent>
            <management:ManagementToolbar SearchText="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                          PlaceholderText="{x:Bind ViewModel.SearchPlaceholderText, Mode=OneWay}"
                                          IconKind="{x:Bind ViewModel.SearchIconKind, Mode=OneWay}"
                                          ClearCommand="{x:Bind ViewModel.ClearSearchCommand, Mode=OneWay}">
                <management:ManagementToolbar.LeadingContent>
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                        <Button x:Name="GridViewButton"
                                Width="48"
                                Height="48"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Padding="0"
                                CornerRadius="8"
                                Background="{x:Bind ViewModel.GridButtonBackgroundBrush, Mode=OneWay}"
                                BorderBrush="{StaticResource LighterGrayBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.ToggleGridViewCommand, Mode=OneWay}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{x:Bind ViewModel.GridButtonBackgroundHoverColor, Mode=OneWay}" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{x:Bind ViewModel.GridButtonForegroundHoverColor, Mode=OneWay}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource LighterGray}" />
                            </Button.Resources>
                            <PathIcon Width="24"
                                      Height="24"
                                      Foreground="{x:Bind ViewModel.GridButtonForegroundBrush, Mode=OneWay}"
                                      Data="{x:Bind ViewModel.GridIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
                        </Button>

                        <Button x:Name="ListViewButton"
                                Width="48"
                                Height="48"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Padding="0"
                                CornerRadius="8"
                                Background="{x:Bind ViewModel.ListButtonBackgroundBrush, Mode=OneWay}"
                                BorderBrush="{StaticResource LighterGrayBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.ToggleListViewCommand, Mode=OneWay}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{x:Bind ViewModel.ListButtonBackgroundHoverColor, Mode=OneWay}" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{x:Bind ViewModel.ListButtonForegroundHoverColor, Mode=OneWay}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource LighterGray}" />
                            </Button.Resources>
                            <PathIcon Width="24"
                                      Height="24"
                                      Foreground="{x:Bind ViewModel.ListButtonForegroundBrush, Mode=OneWay}"
                                      Data="{x:Bind ViewModel.ListIconState, Mode=OneWay, Converter={StaticResource IconConverter}}" />
                        </Button>
                    </StackPanel>
                </management:ManagementToolbar.LeadingContent>

                <management:ManagementToolbar.ActionsContent>
                    <StackPanel x:Name="ToolbarActionsPanel"
                                Orientation="Horizontal"
                                Spacing="10">
                        <management:ManagementToolbarButton WideMinWidth="120"
                                                            IconSize="20"
                                                            IconState="{x:Bind ManageTypesIconState, Mode=OneWay}"
                                                            Text="{x:Bind ViewModel.ManageGameTypesButtonText, Mode=OneWay}"
                                                            Command="{x:Bind ViewModel.ManageGameTypesCommand, Mode=OneWay}" />
                        <management:ManagementToolbarButton WideMinWidth="108"
                                                            IconState="{x:Bind ViewModel.FilterIconState, Mode=OneWay}"
                                                            Text="{x:Bind ViewModel.FilterButtonText, Mode=OneWay}"
                                                            Command="{x:Bind ViewModel.FilterCommand, Mode=OneWay}" />
                        <management:ManagementToolbarButton IsPrimary="True"
                                                            IconState="{x:Bind ViewModel.AddIconState, Mode=OneWay}"
                                                            Text="{x:Bind ViewModel.AddGameButtonText, Mode=OneWay}"
                                                            Command="{x:Bind ViewModel.AddGameCommand, Mode=OneWay}" />
                    </StackPanel>
                </management:ManagementToolbar.ActionsContent>
            </management:ManagementToolbar>
        </management:ManagementPageShell.ToolbarContent>

        <management:ManagementPageShell.BodyContent>
            <ScrollViewer x:Name="GamesScrollViewer"
                          Padding="0"
                          HorizontalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Auto"
                          Loaded="HandleGamesScrollViewerLoaded"
                          SizeChanged="HandleGamesScrollViewerSizeChanged">
                <StackPanel x:Name="ContentPanel"
                            Padding="24,20,24,24"
                            Spacing="20">
                    <management:ManagementSortBar ComboBoxWidth="152"
                                                  SortFieldItemsSource="{x:Bind ViewModel.SortFieldOptions, Mode=OneWay}"
                                                  SelectedSortField="{x:Bind ViewModel.SelectedSortField, Mode=TwoWay}"
                                                  SortDirectionItemsSource="{x:Bind ViewModel.SortDirectionOptions, Mode=OneWay}"
                                                  SelectedSortDirection="{x:Bind ViewModel.SelectedSortDirection, Mode=TwoWay}"
                                                  SortFieldPlaceholderText="{x:Bind ViewModel.SortFieldPlaceholderText, Mode=OneWay}"
                                                  SortDirectionPlaceholderText="{x:Bind ViewModel.SortDirectionPlaceholderText, Mode=OneWay}"
                                                  PageInfoText="{x:Bind ViewModel.PageInfoText, Mode=OneWay}" />

                    <Grid>
                        <Grid Visibility="{x:Bind ViewModel.HasGames, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
                            <Grid Visibility="{x:Bind ViewModel.IsGridView, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.PagedGridGameCards, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MaximumRowsOrColumns="{x:Bind ViewModel.GridGamesMaximumRowsOrColumns, Mode=OneWay}"
                                                           MinItemWidth="{x:Bind ViewModel.GridGamesMinItemWidth, Mode=OneWay}"
                                                           MinItemHeight="{x:Bind ViewModel.GridGamesMinItemHeight, Mode=OneWay}"
                                                           MinColumnSpacing="16"
                                                           MinRowSpacing="16"
                                                           ItemsStretch="Uniform" />
                                    </ItemsRepeater.Layout>

                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="gameViewModels:GridGameCardControlViewModel">
                                            <games:GridGameCardControl />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Grid>

                            <Grid Visibility="{x:Bind ViewModel.IsGridView, Mode=OneWay, Converter={StaticResource BoolToInvisible}}">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.PagedListGameCards, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="16" />
                                    </ItemsRepeater.Layout>

                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="gameViewModels:ListGameCardControlViewModel">
                                            <games:ListGameCardControl />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Grid>
                        </Grid>

                        <management:EmptyStateControl Visibility="{x:Bind ViewModel.HasGames, Mode=OneWay, Converter={StaticResource BoolToInvisible}}"
                                                      IconState="{x:Bind ViewModel.NoGamesIconState, Mode=OneWay}"
                                                      Text="{x:Bind ViewModel.NoGamesText, Mode=OneWay}" />
                    </Grid>

                    <controls:PaginationControl DataContext="{x:Bind ViewModel.PaginationViewModel, Mode=OneWay}"
                                                HorizontalAlignment="Center"
                                                Margin="0,16,0,0" />
                </StackPanel>
            </ScrollViewer>
        </management:ManagementPageShell.BodyContent>
    </management:ManagementPageShell>
</Page>
