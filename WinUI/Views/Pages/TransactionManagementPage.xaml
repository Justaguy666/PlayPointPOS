<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinUI.Views.Pages.TransactionManagementPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:management="using:WinUI.Views.UserControls.Management"
    xmlns:txnControls="using:WinUI.Views.UserControls.Transactions"
    xmlns:txnViewModels="using:WinUI.ViewModels.UserControls.Transactions"
    xmlns:vm="using:WinUI.ViewModels.Pages"
    KeyboardAcceleratorPlacementMode="Hidden"
    d:DataContext="{d:DesignInstance Type=vm:TransactionManagementPageViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <management:ManagementPageShell>
        <management:ManagementPageShell.ToolbarContent>
            <management:ManagementToolbar SearchText="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                          PlaceholderText="{x:Bind ViewModel.SearchPlaceholderText, Mode=OneWay}"
                                          IconKind="{x:Bind ViewModel.SearchIconKind, Mode=OneWay}"
                                          ClearCommand="{x:Bind ViewModel.ClearSearchCommand, Mode=OneWay}">
                <management:ManagementToolbar.ActionsContent>
                    <StackPanel x:Name="ToolbarActionsPanel"
                                Orientation="Horizontal">
                        <management:ManagementToolbarButton WideMinWidth="108"
                                                            IconState="{x:Bind ViewModel.FilterIconState, Mode=OneWay}"
                                                            Text="{x:Bind ViewModel.FilterButtonText, Mode=OneWay}"
                                                            Command="{x:Bind ViewModel.FilterCommand, Mode=OneWay}" />
                    </StackPanel>
                </management:ManagementToolbar.ActionsContent>
            </management:ManagementToolbar>
        </management:ManagementPageShell.ToolbarContent>

        <management:ManagementPageShell.BodyContent>
            <ScrollViewer x:Name="TransactionsScrollViewer"
                          Padding="0"
                          HorizontalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Auto"
                          Loaded="HandleTransactionsScrollViewerLoaded"
                          SizeChanged="HandleTransactionsScrollViewerSizeChanged">
                <StackPanel x:Name="ContentPanel"
                            Padding="24,20,24,24"
                            Spacing="20">
                    <management:PageInfoChip x:Name="PageInfoChip"
                                             Text="{x:Bind ViewModel.PageInfoText, Mode=OneWay}"
                                             HorizontalAlignment="Right" />

                    <Grid HorizontalAlignment="Stretch">
                        <Grid Visibility="{x:Bind ViewModel.HasTransactions, Mode=OneWay, Converter={StaticResource BoolToVisible}}"
                              HorizontalAlignment="Stretch">
                            <ItemsRepeater HorizontalAlignment="Stretch"
                                           ItemsSource="{x:Bind ViewModel.PagedTransactionCards, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MaximumRowsOrColumns="{x:Bind ViewModel.TransactionCardsMaximumRowsOrColumns, Mode=OneWay}"
                                                       MinItemWidth="{x:Bind ViewModel.TransactionCardsMinItemWidth, Mode=OneWay}"
                                                       MinItemHeight="{x:Bind ViewModel.TransactionCardsMinItemHeight, Mode=OneWay}"
                                                       MinColumnSpacing="14"
                                                       MinRowSpacing="14"
                                                       ItemsStretch="Uniform" />
                                </ItemsRepeater.Layout>

                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="txnViewModels:TransactionCardControlViewModel">
                                        <txnControls:TransactionCardControl />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </Grid>

                        <management:EmptyStateControl Visibility="{x:Bind ViewModel.HasTransactions, Mode=OneWay, Converter={StaticResource BoolToInvisible}}"
                                                      IconState="{x:Bind ViewModel.NoTransactionsIconState, Mode=OneWay}"
                                                      Text="{x:Bind ViewModel.NoTransactionsText, Mode=OneWay}" />
                    </Grid>

                    <controls:PaginationControl DataContext="{x:Bind ViewModel.PaginationViewModel, Mode=OneWay}"
                                                HorizontalAlignment="Center"
                                                Margin="0,16,0,0" />
                </StackPanel>
            </ScrollViewer>
        </management:ManagementPageShell.BodyContent>
    </management:ManagementPageShell>
</Page>
