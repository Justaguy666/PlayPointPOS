<UserControl
    x:Class="WinUI.Views.UserControls.AreaManagement.DetailedAreaCards.DetailedRentedCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:uimodels="using:WinUI.UIModels"
    xmlns:helpers="using:WinUI.Helpers"
    x:Name="RootControl"
    mc:Ignorable="d">

    <UserControl.Resources>

        <DataTemplate x:Key="ServiceRowTemplate"
                      x:DataType="uimodels:ServiceInSessionModel">
            <Border Margin="0,0,0,12"
                    Padding="12"
                    Background="{StaticResource VeryLightGrayBrush}"
                    CornerRadius="10">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind Service}"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BlackBrush}" />

                        <TextBlock Text="{x:Bind ServiceInfo, Mode=OneWay}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource DarkGrayBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Visibility="{x:Bind IsProduct, Converter={StaticResource BoolToVisible}}">
                        <Button Style="{StaticResource DialogCompactCapacityButtonStyle}"
                                Command="{x:Bind DecrementQuantityCommand}"
                                Width="28" Height="28" CornerRadius="4"
                                helpers:CursorBehavior.UseHandCursor="True">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="-" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold" />
                        </Button>
                        
                        <TextBlock Text="{x:Bind Quantity, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" MinWidth="20" TextAlignment="Center" Foreground="{StaticResource BlackBrush}" />
                        
                        <Button Style="{StaticResource DialogCompactCapacityButtonStyle}"
                                Command="{x:Bind IncrementQuantityCommand}"
                                Width="28" Height="28" CornerRadius="4"
                                helpers:CursorBehavior.UseHandCursor="True">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="+" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Visibility="{x:Bind IsGame, Converter={StaticResource BoolToVisible}}">
                        <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{x:Bind StartGameCommand}"
                                Padding="12,6" CornerRadius="6"
                                Visibility="{x:Bind IsGameNotStarted, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                                helpers:CursorBehavior.UseHandCursor="True">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="{x:Bind StartGameButtonText}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" />
                        </Button>
                        <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{x:Bind StopGameCommand}"
                                Padding="12,6" CornerRadius="6"
                                Visibility="{x:Bind IsGameRunning, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                                helpers:CursorBehavior.UseHandCursor="True">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="{x:Bind StopGameButtonText}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Margin="0,0,8,0"
                               Text="{x:Bind TotalPriceText, Mode=OneWay}"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryOrangeBrush}"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="3"
                            Style="{StaticResource CardDangerButtonStyle}"
                            Command="{x:Bind DeleteCommand}"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <SymbolIcon Symbol="Delete" Foreground="{StaticResource WhiteBrush}" />
                    </Button>


                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DetailedAreaCardHeaderGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  ColumnSpacing="12"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Width="28"
                      Height="28"
                      Stretch="Uniform"
                      Fill="{StaticResource BlackBrush}"
                      Data="{Binding IconState, Converter={StaticResource IconConverter}, Mode=OneWay}"
                      VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding AreaName, Mode=OneWay}"
                               FontSize="{StaticResource FontSizeExtraExtraExtraLarge}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BlackBrush}" />

                    <TextBlock Text="{Binding MaxCapacityText, Mode=OneWay}"
                               FontSize="{StaticResource FontSizeMedium}"
                               Foreground="{StaticResource DarkGrayBrush}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="{Binding PaidButtonText, Mode=OneWay}"
                        Command="{Binding PaidCommand, Mode=OneWay}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>

                <Button Style="{StaticResource DangerButtonStyle}"
                        Content="{Binding EndSessionButtonText, Mode=OneWay}"
                        Command="{Binding EndSessionCommand, Mode=OneWay}"
                        Visibility="{Binding IsSessionActive, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>

                <Button Style="{StaticResource DetailedAreaCardPrimaryButtonStyle}"
                        Content="{Binding EndSessionButtonText, Mode=OneWay}"
                        Command="{Binding EndSessionCommand, Mode=OneWay}"
                        Visibility="{Binding IsSessionPaused, Mode=OneWay, Converter={StaticResource BoolToVisible}}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SuccessActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollView Grid.Row="1"
                    Padding="20"
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <Border Style="{StaticResource DetailedRentedSectionBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Path Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  Fill="{StaticResource BlackBrush}"
                                  Data="{Binding SessionInfoIconState, Converter={StaticResource IconConverter}, Mode=OneWay}"
                                  VerticalAlignment="Center" />

                            <TextBlock Text="{Binding SessionInfoTitleText, Mode=OneWay}"
                                       FontSize="{StaticResource FontSizeLarge}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlackBrush}" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding SessionStartTimeLabelText, Mode=OneWay}"
                                       Style="{StaticResource KeyValueRowLabelTextStyle}" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding SessionStartTimeText, Mode=OneWay}"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BlackBrush}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding SessionDurationLabelText, Mode=OneWay}"
                                       Style="{StaticResource KeyValueRowLabelTextStyle}" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding SessionDurationText, Mode=OneWay}"
                                       FontSize="{StaticResource SubHeaderFontSize}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryOrangeBrush}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding AreaHourlyPriceLabelText, Mode=OneWay}"
                                       Style="{StaticResource KeyValueRowLabelTextStyle}" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding AreaHourlyPriceText, Mode=OneWay}"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BlackBrush}" />
                        </Grid>

                        <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding AreaSessionTotalPriceLabelText, Mode=OneWay}"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BlackBrush}" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding AreaSessionTotalPriceText, Mode=OneWay}"
                                       FontSize="{StaticResource FontSizeExtraLarge}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryOrangeBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource DetailedRentedSectionBorderStyle}"
                            VerticalAlignment="Stretch">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Fill="{StaticResource BlackBrush}"
                                          Data="{Binding GameSectionIconState, Converter={StaticResource IconConverter}, Mode=OneWay}"
                                          VerticalAlignment="Center" />

                                    <TextBlock Text="{Binding GameServicesTitleText, Mode=OneWay}"
                                               FontSize="{StaticResource FontSizeLarge}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BlackBrush}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource DetailedRentedSectionActionButtonStyle}"
                                        Content="{Binding AddGameButtonText, Mode=OneWay}">
                                    <Button.Resources>
                                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                                    </Button.Resources>
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedRight">
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource LighterGrayBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="CornerRadius" Value="14" />
                                                    <Setter Property="Padding" Value="4" />
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                            <Grid Width="340" RowSpacing="16" Padding="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <AutoSuggestBox Grid.Row="0"
                                                                PlaceholderText="{Binding GameSearchPlaceholderText, Mode=OneWay}"
                                                                QueryIcon="Find"
                                                                Text="{Binding GameSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                    <AutoSuggestBox.Resources>
                                                        <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource LightGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource LightGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource PrimaryOrange}" />
                                                    </AutoSuggestBox.Resources>
                                                </AutoSuggestBox>
                                                <Grid Grid.Row="1">
                                                    <ListView MaxHeight="360"
                                                              ItemsSource="{Binding AvailableGames, Mode=OneWay}"
                                                              SelectionMode="None"
                                                              ItemContainerStyle="{StaticResource DefaultListViewItemStyle}">
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                                        Style="{StaticResource FlyoutItemButtonStyle}"
                                                                        Click="AddGameButton_Click">
                                                                    <Grid Padding="8,12" ColumnSpacing="16" BorderBrush="{StaticResource LighterGrayBrush}" BorderThickness="0,0,0,1" Background="Transparent">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BlackBrush}" HorizontalAlignment="Left" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding PriceText}" Margin="0,0,8,0" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource DarkGrayBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                    <TextBlock Text="{Binding NoDataText, Mode=OneWay}"
                                                               Foreground="{StaticResource DarkGrayBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,32,0,32"
                                                               Visibility="{Binding HasNoGames, Converter={StaticResource BoolToVisible}, Mode=OneWay}" />
                                                </Grid>
                                            </Grid>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding GameServicesInSession, Mode=OneWay}"
                                          ItemTemplate="{StaticResource ServiceRowTemplate}" />

                            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding GameServicesCurrentTotalPriceLabelText, Mode=OneWay}"
                                           FontSize="{StaticResource FontSizeMedium}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BlackBrush}" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding GameServicesCurrentTotalPriceText, Mode=OneWay}"
                                           FontSize="{StaticResource FontSizeExtraLarge}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryOrangeBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource DetailedRentedSectionBorderStyle}"
                            VerticalAlignment="Stretch">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Fill="{StaticResource BlackBrush}"
                                          Data="{Binding ProductSectionIconState, Converter={StaticResource IconConverter}, Mode=OneWay}"
                                          VerticalAlignment="Center" />

                                    <TextBlock Text="{Binding ProductServicesTitleText, Mode=OneWay}"
                                               FontSize="{StaticResource FontSizeLarge}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BlackBrush}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource DetailedRentedSectionActionButtonStyle}"
                                        Content="{Binding AddProductButtonText, Mode=OneWay}">
                                    <Button.Resources>
                                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                                    </Button.Resources>
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedRight">
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource LighterGrayBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="CornerRadius" Value="14" />
                                                    <Setter Property="Padding" Value="4" />
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                            <StackPanel Width="360" Spacing="16" Padding="4">
                                                <AutoSuggestBox PlaceholderText="{Binding ProductSearchPlaceholderText, Mode=OneWay}"
                                                                QueryIcon="Find"
                                                                Text="{Binding ProductSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                    <AutoSuggestBox.Resources>
                                                        <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource White}" />
                                                        <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource Black}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource LightGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource LightGray}" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource PrimaryOrange}" />
                                                    </AutoSuggestBox.Resources>
                                                </AutoSuggestBox>
                                                <Pivot Height="380">
                                                    <Pivot.Resources>
                                                        <SolidColorBrush x:Key="PivotHeaderItemSelectedPipeBrush" Color="{StaticResource PrimaryOrange}" />
                                                        <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource PrimaryOrange}" />
                                                        <SolidColorBrush x:Key="SystemControlHighlightAltAccentBrush" Color="{StaticResource PrimaryOrange}" />
                                                        <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="{StaticResource PrimaryOrange}" />

                                                        <SolidColorBrush x:Key="PivotHeaderItemBackgroundPointerOver" Color="Transparent" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemBackgroundPressed" Color="Transparent" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemBackgroundSelected" Color="Transparent" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemBackgroundSelectedPointerOver" Color="Transparent" />

                                                        <SolidColorBrush x:Key="PivotHeaderItemForeground" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselected" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundPointerOver" Color="{StaticResource PrimaryOrangeDark}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselectedPointerOver" Color="{StaticResource DarkGray}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundSelected" Color="{StaticResource PrimaryOrange}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundSelectedPointerOver" Color="{StaticResource PrimaryOrangeDark}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundPressed" Color="{StaticResource PrimaryOrangeDark}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselectedPressed" Color="{StaticResource PrimaryOrangeDark}" />
                                                        <SolidColorBrush x:Key="PivotHeaderItemForegroundSelectedPressed" Color="{StaticResource PrimaryOrangeDark}" />
                                                    </Pivot.Resources>
                                                    <Pivot.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold" />
                                                        </DataTemplate>
                                                    </Pivot.HeaderTemplate>
                                                    <PivotItem Header="{Binding FoodPivotHeaderText, Mode=OneWay}" Margin="0,16,0,0">
                                                        <Grid>
                                                            <ListView ItemsSource="{Binding AvailableFoods, Mode=OneWay}"
                                                                      SelectionMode="None"
                                                                      ItemContainerStyle="{StaticResource DefaultListViewItemStyle}">
                                                                <ListView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                                                Style="{StaticResource FlyoutItemButtonStyle}"
                                                                                Click="AddProductButton_Click">
                                                                            <Grid Padding="8,12" ColumnSpacing="16" BorderBrush="{StaticResource LighterGrayBrush}" BorderThickness="0,0,0,1" Background="Transparent">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BlackBrush}" HorizontalAlignment="Left" />
                                                                                <TextBlock Grid.Column="1" Text="{Binding PriceText}"  Margin="0,0,8,0" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource DarkGrayBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ListView.ItemTemplate>
                                                            </ListView>
                                                            <TextBlock Text="{Binding NoDataText, Mode=OneWay}"
                                                                       Foreground="{StaticResource DarkGrayBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,32,0,32"
                                                                       Visibility="{Binding HasNoFoods, Converter={StaticResource BoolToVisible}, Mode=OneWay}" />
                                                        </Grid>
                                                    </PivotItem>
                                                    <PivotItem Header="{Binding DrinkPivotHeaderText, Mode=OneWay}" Margin="0,16,0,0">
                                                        <Grid>
                                                            <ListView ItemsSource="{Binding AvailableDrinks, Mode=OneWay}"
                                                                      SelectionMode="None"
                                                                      ItemContainerStyle="{StaticResource DefaultListViewItemStyle}">
                                                                <ListView.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                                                Style="{StaticResource FlyoutItemButtonStyle}"
                                                                                Click="AddProductButton_Click">
                                                                            <Grid Padding="8,12" ColumnSpacing="16" BorderBrush="{StaticResource LighterGrayBrush}" BorderThickness="0,0,0,1" Background="Transparent">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BlackBrush}" HorizontalAlignment="Left" />
                                                                                <TextBlock Grid.Column="1" Text="{Binding PriceText}"  Margin="0,0,8,0" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource DarkGrayBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ListView.ItemTemplate>
                                                            </ListView>
                                                            <TextBlock Text="{Binding NoDataText, Mode=OneWay}"
                                                                       Foreground="{StaticResource DarkGrayBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,32,0,32"
                                                                       Visibility="{Binding HasNoDrinks, Converter={StaticResource BoolToVisible}, Mode=OneWay}" />
                                                        </Grid>
                                                    </PivotItem>
                                                </Pivot>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ProductServicesInSession, Mode=OneWay}"
                                          ItemTemplate="{StaticResource ServiceRowTemplate}" />

                            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ProductServicesTotalPriceLabelText, Mode=OneWay}"
                                           FontSize="{StaticResource FontSizeMedium}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BlackBrush}" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding ProductServicesTotalPriceText, Mode=OneWay}"
                                           FontSize="{StaticResource FontSizeExtraLarge}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryOrangeBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollView>

        <Border Grid.Row="2"
                Padding="32,20"
                Background="{StaticResource PrimaryOrangeBrush}"
                CornerRadius="12,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding CurrentTotalPriceLabelText, Mode=OneWay}"
                           FontSize="{StaticResource FontSizeExtraLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentTotalPriceText, Mode=OneWay}"
                           FontSize="{StaticResource FontSizeExtraExtraLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
