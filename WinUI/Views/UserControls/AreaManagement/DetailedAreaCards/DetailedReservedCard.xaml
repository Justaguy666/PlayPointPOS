<UserControl
    x:Class="WinUI.Views.UserControls.AreaManagement.DetailedAreaCards.DetailedReservedCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.UserControls.AreaManagement.DetailedAreaCards"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:uimodels="using:WinUI.UIModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="ReservationInfoRowTemplate"
                      x:DataType="uimodels:LabelValueRowModel">
            <StackPanel>
                <Grid Padding="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind Label}"
                               Style="{StaticResource KeyValueRowLabelTextStyle}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Value}"
                               Style="{StaticResource KeyValueRowValueTextStyle}"
                               VerticalAlignment="Center"
                               Foreground="{Binding IsHighlighted, Converter={StaticResource BoolToAccentForegroundBrushConverter}}" />
                </Grid>

                <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}"
                                         Visibility="{Binding ShowDivider, Converter={StaticResource BoolToVisible}}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Style="{StaticResource DetailedAreaCardHeaderGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
              ColumnSpacing="16"
              VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                  Width="32"
                  Height="32"
                  Stretch="Uniform"
                  Fill="{StaticResource BlackBrush}"
                  Data="{Binding IconState, Converter={StaticResource IconConverter}, Mode=OneWay}"
                  VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                        Spacing="6"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding AreaName, Mode=OneWay}"
                           FontSize="{StaticResource FontSizeExtraExtraExtraLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BlackBrush}" />

                    <TextBlock Text="{Binding MaxCapacityText, Mode=OneWay}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="Normal"
                           Foreground="{StaticResource DarkGrayBrush}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="8">
                <Button Style="{StaticResource DetailedAreaCardPrimaryButtonStyle}"
                    Content="{Binding CheckInButtonText, Mode=OneWay}"
                    Command="{Binding CheckInCommand, Mode=OneWay}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SuccessActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>

                <Button Style="{StaticResource DetailedAreaCardSecondaryButtonStyle}"
                    Content="{Binding EditButtonText, Mode=OneWay}"
                    Command="{Binding EditCommand, Mode=OneWay}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/InfoActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>

                <Button Style="{StaticResource DangerButtonStyle}"
                    Content="{Binding CancelReservationButtonText, Mode=OneWay}"
                    Command="{Binding CancelReservationCommand, Mode=OneWay}">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,32,0,0"
                Padding="20"
                Background="{StaticResource VeryLightGrayBrush}"
                BorderThickness="1"
                BorderBrush="{StaticResource PrimaryOrangeBrush}"
                CornerRadius="12"
                MinWidth="480"
                MaxWidth="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <ScrollView HorizontalScrollBarVisibility="Hidden"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Background="{StaticResource TransparentBrush}"
                        BorderThickness="0">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding ReservationInfoTitleText}"
                               Foreground="{StaticResource PrimaryOrangeBrush}"
                               FontSize="{StaticResource FontSizeExtraExtraExtraLarge}"
                               FontWeight="Bold"/>

                    <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

                    <ItemsControl ItemsSource="{Binding ReservationInfoRows}"
                                  ItemTemplate="{StaticResource ReservationInfoRowTemplate}" />
                </StackPanel>
            </ScrollView>
        </Border>
    </Grid>
</UserControl>
