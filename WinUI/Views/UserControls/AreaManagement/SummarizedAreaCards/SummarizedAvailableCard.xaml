<UserControl
    x:Class="WinUI.Views.UserControls.AreaManagement.SummarizedAreaCards.SummarizedAvailableCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:WinUI.Helpers"
    xmlns:vm="using:WinUI.ViewModels.AreaManagement.SummarizedAreaCards"
    d:DataContext="{d:DesignInstance Type=vm:SummarizedAvailableCardViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        x:Name="CardBorder"
        MinWidth="180"
        Height="160"
        Padding="16"
        CornerRadius="12"
        HorizontalAlignment="Stretch"
        Background="{StaticResource SummarizedAvailableAreaBackgroundBrush}"
        BorderBrush="{StaticResource SummarizedAreaBorderBrush}"
        BorderThickness="1"
        helpers:CursorBehavior.UseHandCursor="True"
        PointerEntered="HandleCardPointerEntered"
        PointerExited="HandleCardPointerExited"
        PointerPressed="HandleCardPointerPressed"
        PointerReleased="HandleCardPointerReleased"
        PointerCanceled="HandleCardPointerCanceled"
        PointerCaptureLost="HandleCardPointerCaptureLost">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding AreaName}" 
                       Foreground="{StaticResource BlackBrush}"
                       FontSize="{StaticResource FontSizeMedium}"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="1"
                       Text="{Binding AvailableStatusText}" 
                       Foreground="{StaticResource DarkGrayBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
