<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Name="RootCard"
    x:Class="WinUI.Views.UserControls.Dashboard.GoalProgressControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.UserControls.Dashboard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.UserControls.Dashboard"
    d:DataContext="{d:DesignInstance Type=vm:GoalProgressControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Style="{StaticResource SurfaceCardBorderStyle}"
        Height="Auto"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Center">

        <StackPanel Orientation="Vertical"
                    Spacing="12"
                    VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <PathIcon
                    Width="24"
                    Height="24"
                    Data="{Binding IconState, Converter={StaticResource IconConverter}}"
                    Foreground="{StaticResource PrimaryOrangeBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <TextBlock Text="{Binding Title}"
                           FontWeight="Bold" 
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PrimaryOrangeBrush}" />
            </StackPanel>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />
            
            <!-- Monthly Revenue Target Progress -->
            <StackPanel Orientation="Vertical" Spacing="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding RevenueTargetLabel}"
                               FontSize="{StaticResource FontSizeMedium}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Foreground="{StaticResource DashboardMutedTextBrush}" />

                    <TextBlock Grid.Column="1"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource BlackBrush}">
                        <Run Text="{Binding RevenueTargetCurrentValue}" />
                        <Run x:Name="RevenueSeparatorRun" />
                        <Run Text="{Binding RevenueTargetGoalValue}" />
                    </TextBlock>
                </Grid>

                <ProgressBar Minimum="0"
                             Maximum="{Binding RevenueTargetGoalValue}"
                             Value="{Binding RevenueTargetCurrentValue}"
                             Height="16"
                             MinHeight="16"
                             Foreground="{StaticResource PrimaryOrangeBrush}"
                             Background="{StaticResource VeryLightGrayBrush}"
                             CornerRadius="8" />

                <TextBlock Text="{Binding RevenueTargetCompletionText}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource SuccessGreenBrush}" />
            </StackPanel>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <!-- Monthly Customer Target Progress -->
            <StackPanel Orientation="Vertical" Spacing="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding CustomerTargetLabel}"
                               FontSize="{StaticResource FontSizeMedium}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Foreground="{StaticResource DashboardMutedTextBrush}" />

                    <TextBlock Grid.Column="1"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource BlackBrush}">
                        <Run Text="{Binding CustomerTargetCurrentValue}" />
                        <Run x:Name="CustomerSeparatorRun" />
                        <Run Text="{Binding CustomerTargetGoalValue}" />
                    </TextBlock>
                </Grid>

                <ProgressBar Minimum="0"
                             Maximum="{Binding CustomerTargetGoalValue}"
                             Value="{Binding CustomerTargetCurrentValue}"
                             Height="16"
                             MinHeight="16"
                             Foreground="{StaticResource PrimaryOrangeBrush}"
                             Background="{StaticResource VeryLightGrayBrush}"
                             CornerRadius="8" />

                <TextBlock Text="{Binding CustomerTargetCompletionText}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource SuccessGreenBrush}" />
            </StackPanel>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <!-- Monthly Member Target Progress -->
            <StackPanel Orientation="Vertical" Spacing="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding MemberTargetLabel}"
                               FontSize="{StaticResource FontSizeMedium}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Foreground="{StaticResource DashboardMutedTextBrush}" />

                    <TextBlock Grid.Column="1"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource BlackBrush}">
                        <Run Text="{Binding MemberTargetCurrentValue}" />
                        <Run x:Name="MemberSeparatorRun" />
                        <Run Text="{Binding MemberTargetGoalValue}" />
                    </TextBlock>
                </Grid>

                <ProgressBar Minimum="0"
                             Maximum="{Binding MemberTargetGoalValue}"
                             Value="{Binding MemberTargetCurrentValue}"
                             Height="16"
                             MinHeight="16"
                             Foreground="{StaticResource PrimaryOrangeBrush}"
                             Background="{StaticResource VeryLightGrayBrush}"
                             CornerRadius="8" />

                <TextBlock Text="{Binding MemberTargetCompletionText}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource SuccessGreenBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
