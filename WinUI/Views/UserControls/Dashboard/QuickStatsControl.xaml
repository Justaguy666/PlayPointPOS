<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Name="RootCard"
    x:Class="WinUI.Views.UserControls.Dashboard.QuickStatsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.UserControls.Dashboard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:uimodels="using:WinUI.UIModels"
    xmlns:vm="using:WinUI.ViewModels.UserControls.Dashboard"
    d:DataContext="{d:DesignInstance Type=vm:QuickStatsControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="MetricRowTemplate"
                      x:DataType="uimodels:LabelValueRowModel">
            <StackPanel Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind Label}"
                               Style="{StaticResource MetricRowLabelTextStyle}" />

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Value}"
                               Style="{StaticResource MetricRowValueTextStyle}" />
                </Grid>

                <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}"
                                         Visibility="{Binding ShowDivider, Converter={StaticResource BoolToVisible}}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border
        Style="{StaticResource SurfaceCardBorderStyle}"
        Height="Auto"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Center">
        
        <StackPanel Orientation="Vertical"
                    Spacing="12"
                    VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <PathIcon
                    Width="24"
                    Height="24"
                    Data="{Binding IconState, Converter={StaticResource IconConverter}}"
                    Foreground="{StaticResource PrimaryOrangeBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <TextBlock Text="{Binding Title}"
                           FontWeight="Bold" 
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PrimaryOrangeBrush}" />
            </StackPanel>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <ItemsControl ItemsSource="{Binding MetricRows}"
                          ItemTemplate="{StaticResource MetricRowTemplate}" />

        </StackPanel>
    </Border>
</UserControl>
