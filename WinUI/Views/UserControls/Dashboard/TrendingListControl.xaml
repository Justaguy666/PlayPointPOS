<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Dashboard.TrendingListControl"
    x:Name="RootCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.UserControls.Dashboard"
    d:DataContext="{d:DesignInstance Type=vm:TrendingListControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Height="Auto"
        Padding="24"
        Background="{StaticResource WhiteBrush}"
        BorderBrush="{StaticResource LightGrayBrush}"
        BorderThickness="1"
        CornerRadius="12"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Center">

        <StackPanel Orientation="Vertical"
                    Spacing="12"
                    VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <PathIcon
                    Width="24"
                    Height="24"
                    Data="{Binding IconState, Converter={StaticResource IconConverter}}"
                    Foreground="{StaticResource PrimaryOrangeBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <TextBlock Text="{Binding Title}"
                           FontWeight="Bold" 
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PrimaryOrangeBrush}" />
            </StackPanel>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding GameLabel}"
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource DashboardMutedTextBrush}" />

                <TextBlock Grid.Column="1"
                           Text="{Binding GameName}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource BlackBrush}" />
            </Grid>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding FoodLabel}"
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource DashboardMutedTextBrush}" />

                <TextBlock Grid.Column="1"
                           Text="{Binding FoodName}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource BlackBrush}" />
            </Grid>

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding DrinkLabel}"
                           FontSize="{StaticResource FontSizeMedium}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource DashboardMutedTextBrush}" />

                <TextBlock Grid.Column="1"
                           Text="{Binding DrinkName}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource BlackBrush}" />
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
