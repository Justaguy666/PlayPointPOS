<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Dialogs.DialogFooterActions"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button x:Name="SecondaryButton"
                Grid.Column="0"
                Style="{StaticResource DialogSecondaryFooterButtonStyle}"
                Command="{Binding SecondaryCommand, ElementName=RootControl}"
                ToolTipService.ToolTip="{Binding SecondaryText, ElementName=RootControl}">
            <Button.Resources>
                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
            </Button.Resources>
            <TextBlock Text="{Binding SecondaryText, ElementName=RootControl}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1" />
        </Button>

        <Button x:Name="PrimaryButton"
                Grid.Column="1"
                Style="{StaticResource DialogPrimaryFooterButtonStyle}"
                Command="{Binding PrimaryCommand, ElementName=RootControl}"
                IsEnabled="{Binding IsPrimaryEnabled, ElementName=RootControl}"
                ToolTipService.ToolTip="{Binding PrimaryText, ElementName=RootControl}">
            <TextBlock Text="{Binding PrimaryText, ElementName=RootControl}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1" />
        </Button>
    </Grid>
</UserControl>
