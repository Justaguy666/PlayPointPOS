<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Games.GridGameCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:WinUI.ViewModels.UserControls.Games"
    d:DataContext="{d:DesignInstance Type=viewmodels:GridGameCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource WhiteBrush}"
        BorderBrush="{StaticResource LighterGrayBrush}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="176" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="16,16,0,0"
                    Background="{StaticResource AntiqueWhiteBrush}">
                <Image Source="{Binding ImageUri}"
                       Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Row="1"
                        Padding="16"
                        Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{Binding TypeBadgeBackground}"
                            CornerRadius="7"
                            Padding="10,5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding TypeDisplayName}"
                                   Foreground="{Binding TypeBadgeForeground}"
                                   Style="{StaticResource GameCardBadgeTextStyle}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <Button Style="{StaticResource GameCardActionButtonStyle}"
                                Command="{Binding EditCommand}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <PathIcon Width="18"
                                      Height="18"
                                      Foreground="{StaticResource WhiteBrush}"
                                      Data="{Binding EditIconState, Converter={StaticResource IconConverter}}" />
                        </Button>

                        <Button Style="{StaticResource GameCardDangerButtonStyle}"
                                Command="{Binding DeleteCommand}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <PathIcon Width="18"
                                      Height="18"
                                      Foreground="{StaticResource WhiteBrush}"
                                      Data="{Binding DeleteIconState, Converter={StaticResource IconConverter}}" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding Name}"
                           FontSize="{StaticResource FontSizeLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BlackBrush}"
                           TextWrapping="WrapWholeWords"
                           MaxLines="2" />

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <PathIcon Width="18"
                              Height="18"
                              Foreground="{StaticResource SecondaryGrayBrush}"
                              Data="{Binding PlayersIconState, Converter={StaticResource IconConverter}}" />
                    <TextBlock Text="{Binding PlayerRangeText}"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" />
                    <TextBlock Text="{Binding PlayersSuffixText}"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding DifficultyLabelText}"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" />

                    <Border Grid.Column="1"
                            Background="{Binding DifficultyBadgeBackground}"
                            CornerRadius="7"
                            Padding="10,5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <TextBlock Text="{Binding DifficultyDisplayText}"
                                   Foreground="{Binding DifficultyBadgeForeground}"
                                   Style="{StaticResource GameCardBadgeTextStyle}" />
                    </Border>
                </Grid>

                <Border Height="1"
                        Background="{StaticResource LighterGrayBrush}" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding StockLabelText}"
                               Foreground="{StaticResource SecondaryGrayBrush}"
                               FontSize="{StaticResource FontSizeSmall}"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource GameCardStockButtonStyle}"
                                Command="{Binding DecreaseStockCommand}"
                                IsEnabled="{Binding CanDecreaseStock}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="-"
                                       FontSize="{StaticResource FontSizeExtraExtraLarge}"
                                       FontWeight="Bold" />
                        </Button>

                        <TextBlock Text="{Binding StockSummaryText}"
                                   FontSize="{StaticResource FontSizeLarge}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OrangeFocusBrush}"
                                   VerticalAlignment="Center" />

                        <Button Style="{StaticResource GameCardStockButtonStyle}"
                                Command="{Binding IncreaseStockCommand}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="+"
                                       FontSize="{StaticResource FontSizeExtraExtraLarge}"
                                       FontWeight="Bold" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding HourlyPriceLabelText}"
                               Foreground="{StaticResource SecondaryGray}"
                               FontSize="{StaticResource FontSizeSmall}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding HourlyPriceText}"
                               Foreground="{StaticResource PrimaryOrangeBrush}"
                               FontSize="{StaticResource FontSizeExtraLarge}"
                               FontWeight="Bold"
                               HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
