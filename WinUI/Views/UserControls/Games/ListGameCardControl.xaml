<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Games.ListGameCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:WinUI.ViewModels.UserControls.Games"
    d:DataContext="{d:DesignInstance Type=viewmodels:ListGameCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource WhiteBrush}"
        BorderBrush="{StaticResource LighterGrayBrush}"
        BorderThickness="1"
        CornerRadius="16"
        Padding="14">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="116" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="116"
                    Height="92"
                    CornerRadius="14"
                    Background="{StaticResource AntiqueWhiteBrush}"
                    VerticalAlignment="Center">
                <Image Source="{Binding ImageUri}"
                       Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="10">
                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource GameListNameTextStyle}"
                           FontSize="{StaticResource FontSizeLarge}"
                           MaxLines="1" />

                <Grid ColumnSpacing="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding PlayerCountLabelText}"
                                   Style="{StaticResource GameListMetaLabelTextStyle}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <PathIcon Width="18"
                                      Height="18"
                                      Foreground="{StaticResource SecondaryGrayBrush}"
                                      Data="{Binding PlayersIconState, Converter={StaticResource IconConverter}}" />
                            <TextBlock Text="{Binding PlayerRangeText}"
                                       Style="{StaticResource GameListMetaValueTextStyle}" />
                            <TextBlock Text="{Binding PlayersSuffixText}"
                                       Style="{StaticResource GameListMetaLabelTextStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding HourlyPriceLabelText}"
                                   Style="{StaticResource GameListMetaLabelTextStyle}" />
                        <TextBlock Text="{Binding HourlyPriceText}"
                                   Style="{StaticResource GameListPriceTextStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding StockLabelText}"
                                   Style="{StaticResource GameListMetaLabelTextStyle}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Style="{StaticResource GameCardStockButtonStyle}"
                                    Command="{Binding DecreaseStockCommand}"
                                    IsEnabled="{Binding CanDecreaseStock}">
                                <Button.Resources>
                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                                </Button.Resources>
                                <TextBlock Text="-"
                                           FontSize="{StaticResource FontSizeExtraExtraLarge}"
                                           FontWeight="Bold" />
                            </Button>

                            <TextBlock Text="{Binding StockSummaryText}"
                                       Style="{StaticResource GameListMetaValueTextStyle}"
                                       Foreground="{StaticResource OrangeFocusBrush}"
                                       VerticalAlignment="Center" />

                            <Button Style="{StaticResource GameCardStockButtonStyle}"
                                    Command="{Binding IncreaseStockCommand}">
                                <Button.Resources>
                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                                </Button.Resources>
                                <TextBlock Text="+"
                                           FontSize="{StaticResource FontSizeExtraExtraLarge}"
                                           FontWeight="Bold" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="12">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Border Background="{Binding TypeBadgeBackground}"
                            CornerRadius="8"
                            Padding="12,6">
                        <TextBlock Text="{Binding TypeDisplayName}"
                                   Foreground="{Binding TypeBadgeForeground}"
                                   Style="{StaticResource GameCardBadgeTextStyle}" />
                    </Border>

                    <Border Background="{Binding DifficultyBadgeBackground}"
                            CornerRadius="8"
                            Padding="12,6">
                        <TextBlock Text="{Binding DifficultyDisplayText}"
                                   Foreground="{Binding DifficultyBadgeForeground}"
                                   Style="{StaticResource GameCardBadgeTextStyle}" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Style="{StaticResource GameCardActionButtonStyle}"
                            Command="{Binding EditCommand}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <PathIcon Width="18"
                                  Height="18"
                                  Foreground="{StaticResource WhiteBrush}"
                                  Data="{Binding EditIconState, Converter={StaticResource IconConverter}}" />
                    </Button>

                    <Button Style="{StaticResource GameCardDangerButtonStyle}"
                            Command="{Binding DeleteCommand}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <PathIcon Width="18"
                                  Height="18"
                                  Foreground="{StaticResource WhiteBrush}"
                                  Data="{Binding DeleteIconState, Converter={StaticResource IconConverter}}" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
