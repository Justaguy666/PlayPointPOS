<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Management.EmptyStateControl"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource LighterGrayBrush}"
            BorderThickness="1"
            CornerRadius="24"
            Padding="48">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
            <PathIcon Width="52"
                      Height="52"
                      Foreground="{StaticResource PrimaryOrangeBrush}"
                      Data="{Binding IconState, ElementName=RootControl, Converter={StaticResource IconConverter}}" />
            <TextBlock Text="{Binding Text, ElementName=RootControl}"
                       ToolTipService.ToolTip="{Binding Text, ElementName=RootControl}"
                       Foreground="{StaticResource BlackBrush}"
                       FontSize="{StaticResource FontSizeExtraExtraLarge}"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="WrapWholeWords"
                       MaxLines="3" />
        </StackPanel>
    </Border>
</UserControl>
