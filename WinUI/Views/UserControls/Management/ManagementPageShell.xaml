<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Management.ManagementPageShell"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource WhiteBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ContentPresenter Grid.Row="0"
                          Content="{Binding ToolbarContent, ElementName=RootControl}" />

        <Grid Grid.Row="1">
            <Rectangle Fill="{StaticResource PrimaryGradientBrush}" />
            <Rectangle Fill="{StaticResource PatternBrush}"
                       Opacity="0.1" />
            <ContentPresenter Content="{Binding BodyContent, ElementName=RootControl}" />
        </Grid>
    </Grid>
</UserControl>
