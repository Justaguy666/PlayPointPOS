<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Members.MemberCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:memberControls="using:WinUI.Views.UserControls.Members"
    xmlns:viewmodels="using:WinUI.ViewModels.UserControls.Members"
    d:DataContext="{d:DesignInstance Type=viewmodels:MemberCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource LighterGrayBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid MinHeight="168">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="1.65*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Padding="28,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <TextBlock Text="{Binding FullName}"
                               Style="{StaticResource MemberCardNameTextStyle}" />

                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding CodeText}"
                                   Style="{StaticResource MemberCardMetaLabelTextStyle}" />

                        <StackPanel Orientation="Horizontal"
                                    Spacing="10">
                            <FontIcon Glyph="&#xE717;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="18"
                                      Foreground="{StaticResource SecondaryGrayBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PhoneNumber}"
                                       Style="{StaticResource MemberCardMetaValueTextStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="28,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding TotalSpentLabelText}"
                                   Style="{StaticResource MemberCardMetaLabelTextStyle}" />
                        <TextBlock Text="{Binding TotalSpentText}"
                                   Style="{StaticResource MemberCardSpentTextStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Button Style="{StaticResource CardActionButtonStyle}"
                                Command="{Binding EditCommand}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <FontIcon Glyph="&#xE70F;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="14"
                                      Foreground="{StaticResource WhiteBrush}" />
                        </Button>

                        <Button Style="{StaticResource CardDangerButtonStyle}"
                                Command="{Binding DeleteCommand}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                            </Button.Resources>
                            <FontIcon Glyph="&#xE74D;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="14"
                                      Foreground="{StaticResource WhiteBrush}" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="30,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="14">
                    <TextBlock Text="{Binding ProgressPercentageText}"
                               Style="{StaticResource MemberCardProgressTextStyle}"
                               Foreground="{Binding ProgressForegroundBrush}"
                               HorizontalAlignment="Right" />

                    <Border Background="{Binding PackageBadgeBackground}"
                            CornerRadius="10"
                            Padding="14,8"
                            HorizontalAlignment="Right">
                        <TextBlock Text="{Binding MembershipRankName}"
                                   Style="{StaticResource MemberCardBadgeTextStyle}"
                                   Foreground="{Binding PackageBadgeForeground}" />
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource LighterGrayBrush}" />

            <memberControls:MemberProgressTankControl Grid.Column="2"
                                                      FillPercentage="{Binding ProgressPercentage}"
                                                      BackgroundBrush="{Binding TankBackgroundBrush}"
                                                      WaterBrush="{Binding TankWaterBrush}"
                                                      BubbleBrush="{Binding TankBubbleBrush}" />
        </Grid>
    </Border>
</UserControl>
