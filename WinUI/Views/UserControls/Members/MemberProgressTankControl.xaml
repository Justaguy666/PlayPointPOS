<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Members.MemberProgressTankControl"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Storyboard x:Key="BubbleOneStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleOneTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="20"
                             To="-110"
                             Duration="0:0:5.2"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleOne"
                             Storyboard.TargetProperty="Opacity"
                             From="0.1"
                             To="0.7"
                             Duration="0:0:1.3"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleTwoStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleTwoTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="18"
                             To="-120"
                             Duration="0:0:4.6"
                             BeginTime="0:0:0.4"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleTwo"
                             Storyboard.TargetProperty="Opacity"
                             From="0.12"
                             To="0.72"
                             Duration="0:0:1.2"
                             BeginTime="0:0:0.2"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleThreeStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleThreeTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="30"
                             To="-135"
                             Duration="0:0:6.1"
                             BeginTime="0:0:0.7"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleThree"
                             Storyboard.TargetProperty="Opacity"
                             From="0.08"
                             To="0.6"
                             Duration="0:0:1.5"
                             BeginTime="0:0:0.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleFourStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleFourTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="14"
                             To="-95"
                             Duration="0:0:4.2"
                             BeginTime="0:0:0.9"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleFour"
                             Storyboard.TargetProperty="Opacity"
                             From="0.1"
                             To="0.68"
                             Duration="0:0:1.1"
                             BeginTime="0:0:0.6"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleFiveStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleFiveTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="22"
                             To="-125"
                             Duration="0:0:5.5"
                             BeginTime="0:0:0.25"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleFive"
                             Storyboard.TargetProperty="Opacity"
                             From="0.15"
                             To="0.76"
                             Duration="0:0:1.4"
                             BeginTime="0:0:0.1"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleSixStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleSixTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="24"
                             To="-105"
                             Duration="0:0:4.9"
                             BeginTime="0:0:1.1"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleSix"
                             Storyboard.TargetProperty="Opacity"
                             From="0.1"
                             To="0.7"
                             Duration="0:0:1.35"
                             BeginTime="0:0:0.8"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleSevenStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleSevenTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="16"
                             To="-118"
                             Duration="0:0:5.8"
                             BeginTime="0:0:0.3"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleSeven"
                             Storyboard.TargetProperty="Opacity"
                             From="0.12"
                             To="0.7"
                             Duration="0:0:1.25"
                             BeginTime="0:0:0.4"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
        <Storyboard x:Key="BubbleEightStoryboard">
            <DoubleAnimation Storyboard.TargetName="BubbleEightTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="28"
                             To="-132"
                             Duration="0:0:6.4"
                             BeginTime="0:0:0.95"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="BubbleEight"
                             Storyboard.TargetProperty="Opacity"
                             From="0.08"
                             To="0.58"
                             Duration="0:0:1.65"
                             BeginTime="0:0:0.9"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource LighterGrayBrush}"
            BorderThickness="0"
            Background="{x:Bind BackgroundBrush, Mode=OneWay}">
        <Grid x:Name="TankLayoutRoot">
            <Border x:Name="WaterFill"
                    VerticalAlignment="Bottom"
                    Background="{x:Bind WaterBrush, Mode=OneWay}">
                <Grid>
                    <Rectangle Height="8"
                               VerticalAlignment="Top"
                               Fill="{StaticResource WhiteBrush}"
                               Opacity="0.22" />

                    <Canvas x:Name="BubbleCanvas"
                            IsHitTestVisible="False">
                        <Ellipse x:Name="BubbleOne"
                                 Width="28"
                                 Height="28"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="88">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleOneTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleTwo"
                                 Width="18"
                                 Height="18"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="104">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleTwoTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleThree"
                                 Width="34"
                                 Height="34"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="96">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleThreeTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleFour"
                                 Width="20"
                                 Height="20"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="78">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleFourTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleFive"
                                 Width="30"
                                 Height="30"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="98">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleFiveTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleSix"
                                 Width="22"
                                 Height="22"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="86">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleSixTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleSeven"
                                 Width="32"
                                 Height="32"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="108">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleSevenTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="BubbleEight"
                                 Width="18"
                                 Height="18"
                                 Fill="{x:Bind BubbleBrush, Mode=OneWay}"
                                 Canvas.Top="92">
                            <Ellipse.RenderTransform>
                                <CompositeTransform x:Name="BubbleEightTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
