<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.MenuControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:models="using:WinUI.UIModels"
    xmlns:vm="using:WinUI.ViewModels"
    mc:Ignorable="d"
    x:Name="RootMenu">

    <StackPanel Orientation="Vertical"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">

        <ItemsControl ItemsSource="{Binding MenuItems}" x:Name="ItemsControlMenu">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:MenuItemModel">
                    <controls:MenuItemControl
                        Text="{x:Bind Label, Mode=OneWay}"
                        IconKind="{x:Bind Icon, Mode=OneWay}"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisible}}"
                        Command="{x:Bind OnMenuItemSelectedCommand, Mode=OneWay}"
                        CommandParameter="{x:Bind}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
