<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.MenuItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <Button x:Name="RootButton"
            Width="230" Height="60"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Background="#FFF8F0"
            Foreground="#FF6B35"
            BorderBrush="#FF8C61"
            BorderThickness="1"
            CornerRadius="12"
            Margin="0,8"
            IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
            Command="{x:Bind Command, Mode=OneWay}"
            CommandParameter="{x:Bind CommandParameter, Mode=OneWay}"
            >

        <Button.Resources>
            <!-- Override Hover -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B35" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFF8F0" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FF8C61" />

            <!-- Override Pressed -->
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E55A2B" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFF8F0" />
        </Button.Resources>

        <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    >

            <FontIcon Glyph="{x:Bind IconGlyph, Mode=OneWay}" 
                      FontSize="22"
                      FontWeight="SemiBold"
                      />

            <TextBlock Text="{x:Bind Text, Mode=OneWay}" 
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       />
            
        </StackPanel>
        
    </Button>
</UserControl>
