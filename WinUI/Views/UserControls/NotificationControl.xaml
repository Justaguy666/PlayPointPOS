<UserControl
    x:Class="WinUI.Views.UserControls.NotificationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI.Views.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="RootControl"
    IsHitTestVisible="True"
    Visibility="Collapsed"
    RenderTransformOrigin="0.5,0.5">

    <UserControl.RenderTransform>
        <TranslateTransform x:Name="RootTranslate" Y="20" />
    </UserControl.RenderTransform>

    <UserControl.Resources>
        <Storyboard x:Name="ShowAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootControl" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseOut" Exponent="4" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="20" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseOut" Exponent="5" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Name="HideAnim" Completed="HideAnim_Completed">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootControl" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" Exponent="4" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="20">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" Exponent="4" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="ContainerBorder"
                Background="#FFFFFF"
                CornerRadius="14"
                BorderThickness="1"
                BorderBrush="#E5E7EB"
                Padding="16,14">
            <!-- Custom Shadow using a blurred border behind if needed, but a simple border is sleek -->

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="IconContainer"
                      Width="32" Height="32"
                      CornerRadius="16"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Background="#D1FAE5">
                    <FontIcon x:Name="IconGlyph"
                              Glyph="&#xE73E;"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#10B981" />
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleBlock"
                               Text="Title"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#111827" 
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="MessageBlock"
                               Text="Message description goes here..."
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="28" Height="28"
                        Margin="12,0,0,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnCloseButtonClick"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F3F4F6"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5E7EB"/>
                    </Button.Resources>
                    <FontIcon Glyph="&#xE8BB;" FontSize="11" Foreground="#9CA3AF" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
