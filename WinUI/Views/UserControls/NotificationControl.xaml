<UserControl
    x:Class="WinUI.Views.UserControls.NotificationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="RootControl"
    IsHitTestVisible="True"
    Visibility="Collapsed"
    RenderTransformOrigin="0.5,0.5">

    <UserControl.RenderTransform>
        <TranslateTransform x:Name="RootTranslate" Y="20" />
    </UserControl.RenderTransform>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Resources/Animations/NotificationAnimations.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border
            Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource LighterGrayBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16,14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    Width="32"
                    Height="32"
                    Margin="0,0,12,0"
                    Background="{Binding IconBackground}"
                    CornerRadius="16"
                    VerticalAlignment="Center">
                    <PathIcon 
                        Width="24"
                        Height="24"
                        Data="{Binding IconState, Converter={StaticResource IconConverter}}"
                        Foreground="{StaticResource BlackBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="{StaticResource FontSizeMedium}"
                        FontWeight="Bold"
                        Foreground="{StaticResource BlackBrush}"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="{StaticResource FontSizeSmall}"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="{Binding Message}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="28"
                    Height="28"
                    Margin="12,0,0,0"
                    Padding="0"
                    Background="{StaticResource TransparentBrush}"
                    BorderThickness="0"
                    Command="{Binding CloseCommand}"
                    ToolTipService.ToolTip="{Binding CloseTooltipText}"
                    VerticalAlignment="Center">
                    <Button.Resources>
                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DialogCloseButtonStateResources.xaml" />
                    </Button.Resources>
                    <FontIcon
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="{StaticResource FontSizeSmall}"
                        Foreground="{StaticResource PlaceholderGrayBrush}"
                        Glyph="&#xE8BB;" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
