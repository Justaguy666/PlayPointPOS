<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.PaginationControl"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinUI.UIModels"
    xmlns:vm="using:WinUI.ViewModels.UserControls"
    d:DataContext="{d:DesignInstance Type=vm:PaginationControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Grid RowSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Center">
            <Button Style="{StaticResource PaginationNavigationButtonStyle}"
                    Command="{Binding GoToFirstPageCommand}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationNavigationButtonStateResources.xaml" />
                </Button.Resources>
                <TextBlock Text="&lt;&lt;" />
            </Button>

            <Button Style="{StaticResource PaginationNavigationButtonStyle}"
                    Command="{Binding GoToPreviousPageCommand}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationNavigationButtonStateResources.xaml" />
                </Button.Resources>
                <TextBlock Text="&lt;" />
            </Button>

            <ItemsControl ItemsSource="{Binding PageButtons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:PaginationPageButtonModel">
                        <Button Style="{StaticResource PaginationPageButtonStyle}"
                                Background="{Binding Background}"
                                BorderBrush="{Binding BorderBrush}"
                                Foreground="{Binding Foreground}"
                                Command="{Binding DataContext.SelectPageCommand, ElementName=RootControl}"
                                CommandParameter="{Binding PageNumber}"
                                IsHitTestVisible="{Binding IsSelected, Converter={StaticResource BoolInverter}}">
                            <Button.Resources>
                                <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationPageButtonStateResources.xaml" />
                            </Button.Resources>
                            <TextBlock Text="{Binding Label}" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Style="{StaticResource PaginationNavigationButtonStyle}"
                    Command="{Binding GoToNextPageCommand}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationNavigationButtonStateResources.xaml" />
                </Button.Resources>
                <TextBlock Text="&gt;" />
            </Button>

            <Button Style="{StaticResource PaginationNavigationButtonStyle}"
                    Command="{Binding GoToLastPageCommand}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationNavigationButtonStateResources.xaml" />
                </Button.Resources>
                <TextBlock Text="&gt;&gt;" />
            </Button>

            <Button Style="{StaticResource PaginationJumpButtonStyle}"
                    Command="{Binding OpenJumpToPageCommand}">
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                </Button.Resources>
                <StackPanel Orientation="Horizontal"
                            Spacing="12">
                    <PathIcon Data="{Binding JumpToPageIconState, Converter={StaticResource IconConverter}, Mode=OneWay}" />
                    <TextBlock Text="{Binding JumpToPageButtonText}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1"
              HorizontalAlignment="Right"
              Margin="0,0,0,0"
              Visibility="{Binding IsJumpToPageOpen, Converter={StaticResource BoolToVisible}, Mode=OneWay}">
            <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Path Grid.Row="0"
                          Width="28"
                          Height="16"
                          Margin="0,0,32,-2"
                          HorizontalAlignment="Right"
                          Fill="{StaticResource WhiteBrush}"
                          StrokeThickness="0"
                          Data="M 0 16 L 14 0 L 28 16 Z" />

                    <Border Grid.Row="1"
                            Background="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            CornerRadius="12"
                            Padding="16,16"
                            MinWidth="240">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>

                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding JumpToPageTitleText}"
                                       Foreground="{StaticResource PrimaryOrangeBrush}"
                                       FontSize="{StaticResource FontSizeLarge}"
                                       FontWeight="Bold" />

                            <TextBox Text="{Binding JumpPageInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DialogFormTextBoxStyle}"
                                     PlaceholderText="{Binding JumpPageRangeText}"
                                     FontSize="{StaticResource FontSizeMedium}"
                                     MinHeight="48">
                                <TextBox.Resources>
                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
                                </TextBox.Resources>
                                <TextBox.InputScope>
                                    <InputScope>
                                        <InputScope.Names>
                                            <InputScopeName NameValue="Number" />
                                        </InputScope.Names>
                                    </InputScope>
                                </TextBox.InputScope>
                            </TextBox>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Style="{StaticResource PaginationDialogSecondaryButtonStyle}"
                                        Command="{Binding CloseJumpToPageCommand}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Resources>
                                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/SecondaryActionButtonStateResources.xaml" />
                                    </Button.Resources>
                                    <TextBlock Text="{Binding CancelButtonText}" />
                                </Button>

                                <Button Grid.Column="1"
                                        Style="{StaticResource PaginationDialogPrimaryButtonStyle}"
                                        Command="{Binding ConfirmJumpToPageCommand}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Resources>
                                        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PaginationDialogPrimaryButtonStateResources.xaml" />
                                    </Button.Resources>
                                    <TextBlock Text="{Binding ConfirmButtonText}" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
        </Grid>
    </Grid>
</UserControl>
