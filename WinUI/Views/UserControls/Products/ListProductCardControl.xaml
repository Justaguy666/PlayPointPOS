<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Products.ListProductCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:WinUI.ViewModels.UserControls.Products"
    d:DataContext="{d:DesignInstance Type=viewmodels:ListProductCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource WhiteBrush}"
        BorderBrush="{StaticResource LighterGrayBrush}"
        BorderThickness="1"
        CornerRadius="16"
        Padding="14">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="116" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="116"
                    Height="92"
                    CornerRadius="14"
                    Background="{StaticResource AntiqueWhiteBrush}"
                    VerticalAlignment="Center">
                <Image Source="{Binding ImageUri}"
                       Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="10">
                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource ListCardNameTextStyle}"
                           FontSize="{StaticResource FontSizeLarge}"
                           MaxLines="1" />

                <Grid ColumnSpacing="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding PriceLabelText}"
                                   Style="{StaticResource ListCardMetaLabelTextStyle}" />
                        <TextBlock Text="{Binding PriceText}"
                                   Style="{StaticResource ListCardAccentValueTextStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="12">
                <Border Background="{Binding TypeBadgeBackground}"
                        CornerRadius="8"
                        Padding="12,6"
                        HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TypeDisplayName}"
                               Foreground="{Binding TypeBadgeForeground}"
                               Style="{StaticResource CardBadgeTextStyle}" />
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Style="{StaticResource CardActionButtonStyle}"
                            Command="{Binding EditCommand}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <PathIcon Width="18"
                                  Height="18"
                                  Foreground="{StaticResource WhiteBrush}"
                                  Data="{Binding EditIconState, Converter={StaticResource IconConverter}}" />
                    </Button>

                    <Button Style="{StaticResource CardDangerButtonStyle}"
                            Command="{Binding DeleteCommand}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/DangerActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <PathIcon Width="18"
                                  Height="18"
                                  Foreground="{StaticResource WhiteBrush}"
                                  Data="{Binding DeleteIconState, Converter={StaticResource IconConverter}}" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
