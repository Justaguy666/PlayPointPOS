<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.SearchControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Height="48" CornerRadius="8" 
          Background="{StaticResource WhiteBrush}"
          BorderBrush="{StaticResource LighterGrayBrush}"
          BorderThickness="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Search Icon -->
        <PathIcon
            Grid.Column="0"
            Width="24"
            Height="24"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Foreground="{StaticResource BlackBrush}"
            Data="{x:Bind IconPath, Mode=OneWay, Converter={StaticResource IconConverter}}" />

        <!-- Search TextBox -->
        <TextBox
            Grid.Column="1"
            x:Name="SearchTextBox"
            Margin="12,0,12,0"
            VerticalAlignment="Center"
            PlaceholderText="{x:Bind PlaceholderText, Mode=OneWay}"
            PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
            Text="{x:Bind SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Background="Transparent"
            Foreground="{StaticResource BlackBrush}"
            BorderThickness="0"
            FontSize="{StaticResource FontSizeMedium}"
            GotFocus="SearchTextBox_GotFocus"
            LostFocus="SearchTextBox_LostFocus">
            <TextBox.Resources>
                <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="TransparentBrush" />
                <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="TransparentBrush" />
                <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="TransparentBrush" />
                <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="TransparentBrush" />
                <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush" />
                <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush" />
                <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush" />
                <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush" />
                <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush" />
                <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush" />
            </TextBox.Resources>
        </TextBox>
    </Grid>
</UserControl>
