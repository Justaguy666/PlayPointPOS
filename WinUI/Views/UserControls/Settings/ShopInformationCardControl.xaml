<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Settings.ShopInformationCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.UserControls.Settings"
    d:DataContext="{d:DesignInstance Type=vm:ShopInformationCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Padding="24"
        Background="{StaticResource WhiteBrush}"
        BorderBrush="{StaticResource LightGrayBrush}"
        BorderThickness="1"
        CornerRadius="12"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="{Binding Title}"
                       FontSize="{StaticResource SubtitleTextBlockFontSize}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BlackBrush}" />

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="{Binding ShopNameLabel}"
                           FontSize="{StaticResource LabelFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BlackBrush}" />

                <TextBox Text="{Binding ShopName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{Binding ShopNamePlaceholder}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         FontSize="{StaticResource ValueFontSize}"
                         Foreground="{StaticResource BlackBrush}"
                         BorderBrush="{StaticResource LightGrayBrush}"
                         BorderThickness="1"
                         CornerRadius="7"
                         Padding="12">
                    <TextBox.Resources>
                        <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="{Binding AddressLabel}"
                           FontSize="{StaticResource LabelFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BlackBrush}" />

                <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{Binding AddressPlaceholder}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         FontSize="{StaticResource ValueFontSize}"
                         Foreground="{StaticResource BlackBrush}"
                         BorderBrush="{StaticResource LightGrayBrush}"
                         BorderThickness="1"
                         CornerRadius="7"
                         Padding="12">
                    <TextBox.Resources>
                        <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                        <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="{Binding EmailLabel}"
                               FontSize="{StaticResource LabelFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BlackBrush}" />

                    <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="{Binding EmailPlaceholder}"
                             PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                             FontSize="{StaticResource ValueFontSize}"
                             Foreground="{StaticResource BlackBrush}"
                             BorderBrush="{StaticResource LightGrayBrush}"
                             BorderThickness="1"
                             CornerRadius="7"
                             Padding="12">
                        <TextBox.Resources>
                            <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                            <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="{Binding EmailErrorMessage}"
                               Visibility="{Binding HasEmailError, Converter={StaticResource BoolToVisible}}"
                               Foreground="{StaticResource ErrorRedBrush}"
                               FontSize="{StaticResource FontSizeSmall}"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            Spacing="4">
                    <TextBlock Text="{Binding PhoneLabel}"
                               FontSize="{StaticResource LabelFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BlackBrush}" />

                    <TextBox Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="{Binding PhonePlaceholder}"
                             PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                             FontSize="{StaticResource ValueFontSize}"
                             Foreground="{StaticResource BlackBrush}"
                             BorderBrush="{StaticResource LightGrayBrush}"
                             BorderThickness="1"
                             CornerRadius="7"
                             Padding="12">
                        <TextBox.Resources>
                            <StaticResource x:Key="TextControlBackground" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="WhiteBrush"/>
                            <StaticResource x:Key="TextControlForeground" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="BlackBrush"/>
                            <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="OrangeFocusBrush"/>
                            <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="MediumGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="PlaceholderGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="PlaceholderGrayBrush"/>
                            <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="PlaceholderGrayBrush"/>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="{Binding PhoneErrorMessage}"
                               Visibility="{Binding HasPhoneError, Converter={StaticResource BoolToVisible}}"
                               Foreground="{StaticResource ErrorRedBrush}"
                               FontSize="{StaticResource FontSizeSmall}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Grid>

            <Button Command="{Binding ApplyCommand}"
                    HorizontalAlignment="Right"
                    CornerRadius="7"
                    Padding="24,10"
                    FontSize="{StaticResource FontSizeMedium}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WhiteBrush}"
                    Background="{StaticResource OrangeFocusBrush}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="PrimaryOrangeBrush"/>
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="PrimaryOrangeBrush"/>
                    <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="WhiteBrush"/>
                    <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="WhiteBrush"/>
                    <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="LighterGrayBrush"/>
                    <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="MediumDarkGrayBrush"/>
                </Button.Resources>
                <TextBlock Text="{Binding ApplyButtonDisplay}" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>
