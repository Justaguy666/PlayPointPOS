<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.Settings.ShopInformationCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:vm="using:WinUI.ViewModels.UserControls.Settings"
    d:DataContext="{d:DesignInstance Type=vm:ShopInformationCardControlViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/FormInputStateResources.xaml" />
    </UserControl.Resources>

    <Border
        Style="{StaticResource SurfaceCardBorderStyle}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="{Binding Title}"
                       Style="{StaticResource CardTitleTextStyle}" />

            <controls:DividerControl DividerBrush="{StaticResource LighterGrayBrush}" />

            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="{Binding ShopNameLabel}"
                           Style="{StaticResource FieldLabelTextStyle}" />

                <TextBox Text="{Binding ShopName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{Binding ShopNamePlaceholder}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         FontSize="{StaticResource ValueFontSize}"
                         Foreground="{StaticResource BlackBrush}"
                         BorderBrush="{StaticResource LightGrayBrush}"
                         BorderThickness="1"
                         CornerRadius="7"
                         Padding="12" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="{Binding AddressLabel}"
                           Style="{StaticResource FieldLabelTextStyle}" />

                <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{Binding AddressPlaceholder}"
                         PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                         FontSize="{StaticResource ValueFontSize}"
                         Foreground="{StaticResource BlackBrush}"
                         BorderBrush="{StaticResource LightGrayBrush}"
                         BorderThickness="1"
                         CornerRadius="7"
                         Padding="12" />
            </StackPanel>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="{Binding EmailLabel}"
                               Style="{StaticResource FieldLabelTextStyle}" />

                    <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="{Binding EmailPlaceholder}"
                             PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                             FontSize="{StaticResource ValueFontSize}"
                             Foreground="{StaticResource BlackBrush}"
                             BorderBrush="{StaticResource LightGrayBrush}"
                             BorderThickness="1"
                             CornerRadius="7"
                             Padding="12" />

                    <TextBlock Text="{Binding EmailErrorMessage}"
                               Visibility="{Binding HasEmailError, Converter={StaticResource BoolToVisible}}"
                               Style="{StaticResource FieldErrorTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            Spacing="4">
                    <TextBlock Text="{Binding PhoneLabel}"
                               Style="{StaticResource FieldLabelTextStyle}" />

                    <TextBox Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="{Binding PhonePlaceholder}"
                             PlaceholderForeground="{StaticResource PlaceholderGrayBrush}"
                             FontSize="{StaticResource ValueFontSize}"
                             Foreground="{StaticResource BlackBrush}"
                             BorderBrush="{StaticResource LightGrayBrush}"
                             BorderThickness="1"
                             CornerRadius="7"
                             Padding="12" />

                    <TextBlock Text="{Binding PhoneErrorMessage}"
                               Visibility="{Binding HasPhoneError, Converter={StaticResource BoolToVisible}}"
                               Style="{StaticResource FieldErrorTextStyle}" />
                </StackPanel>
            </Grid>

            <Button Command="{Binding ApplyCommand}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    HorizontalAlignment="Right"
                    Padding="24,10"
                    >
                <Button.Resources>
                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/PrimaryActionButtonStateResources.xaml" />
                </Button.Resources>
                <TextBlock Text="{Binding ApplyButtonText}" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>
