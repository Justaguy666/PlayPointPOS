<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI.Views.UserControls.SidebarControl"
    x:Name="RootSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI.Views.UserControls"
    xmlns:converters="using:WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BoolToOrangeBrushConverter x:Key="SidebarBoolToOrangeBrushConverter" />
            <converters:BoolToVisibleConverter x:Key="SidebarBoolToVisible" />
            <converters:BoolToInvisibleConverter x:Key="SidebarBoolToInvisible" />

            <Style x:Key="SidebarActionButtonStyle"
                   TargetType="Button">
                <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Height" Value="48" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="SidebarToggleButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource CircularIconActionButtonStyle}">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="44" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Width="{Binding SidebarWidth, Mode=OneWay}"
            Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource LighterGrayBrush}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource LighterGrayBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource SidebarToggleButtonStyle}"
                            ToolTipService.ToolTip="{Binding ToggleSidebarToolTipText}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/CircularIconActionButtonStateResources.xaml" />
                        </Button.Resources>
                        <PathIcon Width="20"
                                  Height="20"
                                  Data="{Binding ToggleSidebarIconState, Converter={StaticResource IconConverter}}"
                                  Foreground="{StaticResource DarkGrayBrush}" />
                    </Button>

                    <controls:LogoControl Grid.Column="1"
                                          Width="138"
                                          Height="52"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsSidebarExpanded, Converter={StaticResource SidebarBoolToVisible}}" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,12">
                <ItemsRepeater ItemsSource="{Binding NavigationItems}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical"
                                     Spacing="4" />
                    </ItemsRepeater.Layout>

                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.NavigateCommand, ElementName=RootSidebar}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SidebarActionButtonStyle}"
                                    Margin="10,0"
                                    ToolTipService.ToolTip="{Binding Label}">
                                <Button.Resources>
                                    <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/NavbarItemButtonStateResources.xaml" />
                                </Button.Resources>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="26"
                                            CornerRadius="2"
                                            Background="{StaticResource PrimaryOrangeBrush}"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsSelected, Converter={StaticResource SidebarBoolToVisible}}" />

                                    <PathIcon Grid.Column="1"
                                              Width="21"
                                              Height="21"
                                              Data="{Binding IconState, Converter={StaticResource IconConverter}}"
                                              Foreground="{Binding IsSelected, Converter={StaticResource SidebarBoolToOrangeBrushConverter}}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Label}"
                                               FontSize="{StaticResource FontSizeMedium}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding IsSelected, Converter={StaticResource SidebarBoolToOrangeBrushConverter}}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding DataContext.IsSidebarExpanded, ElementName=RootSidebar, Converter={StaticResource SidebarBoolToVisible}}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource LighterGrayBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="10,12">
                <StackPanel Spacing="6">
                    <Button Command="{Binding ChangePasswordCommand}"
                            Style="{StaticResource SidebarActionButtonStyle}"
                            ToolTipService.ToolTip="{Binding ChangePasswordButtonText}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/NavbarItemButtonStateResources.xaml" />
                        </Button.Resources>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <PathIcon Grid.Column="1"
                                      Width="20"
                                      Height="20"
                                      Data="{Binding ChangePasswordIconState, Converter={StaticResource IconConverter}}"
                                      Foreground="{StaticResource DarkGrayBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding ChangePasswordButtonText}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource SidebarBoolToVisible}}" />
                        </Grid>
                    </Button>

                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarActionButtonStyle}"
                            ToolTipService.ToolTip="{Binding LogoutButtonText}">
                        <Button.Resources>
                            <ResourceDictionary Source="ms-appx:///Resources/Styles/StateResources/NavbarItemButtonStateResources.xaml" />
                        </Button.Resources>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <PathIcon Grid.Column="1"
                                      Width="20"
                                      Height="20"
                                      Data="{Binding LogoutIconState, Converter={StaticResource IconConverter}}"
                                      Foreground="{StaticResource DangerButtonBackgroundBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding LogoutButtonText}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DangerButtonBackgroundBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource SidebarBoolToVisible}}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
