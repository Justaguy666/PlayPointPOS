    </Page>
    <Page Update="Views\UserControls\MenuItemControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\UserControls\MenuControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\UserControls\LogoControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\UserControls\HeaderControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\UserControls\NavbarControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\Pages\DashboardPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\Pages\StartingPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\Windows\MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Views\UserControls\NotificationControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Themes\Generic.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  
  <Target Name="_RemoveEmptyInfrastructurePri" BeforeTargets="_GenerateProjectPriConfigurationFiles;_GetPriFilesFromPayload;_ComputeInputPriFiles">
    <ItemGroup>
      <_PriFile Remove="@(_PriFile)" Condition="'%(Filename)' == 'Infrastructure'" />
      <ProjectPriFile Remove="@(ProjectPriFile)" Condition="'%(Filename)' == 'Infrastructure'" />
      <PriPayloadFile Remove="@(PriPayloadFile)" Condition="$([System.String]::new('%(Identity)').Contains('Infrastructure.pri'))" />
    </ItemGroup>
  </Target>
  <ItemGroup>
    <None Remove="Resources\Styles\CheckBoxStyles.xaml" />
    <None Remove="Resources\Styles\ScrollBarStyles.xaml" />
    <None Remove="Resources\Styles\ComboBoxStyles.xaml" />
    <None Remove="Resources\Animations\NotificationAnimations.xaml" />
    <None Remove="Resources\Colors.xaml" />
    <None Remove="Resources\FontSize.xaml" />
    <None Remove="Resources\Images.xaml" />
    <None Remove="Views\Dialogs\ConfirmationDialog.xaml" />
    <None Remove="Views\Dialogs\ForgotPasswordDialog.xaml" />
    <None Remove="Views\Dialogs\OtpDialog.xaml" />
    <None Remove="Views\UserControls\Dashboard\GoalProgressControl.xaml" />
    <None Remove="Views\UserControls\Dashboard\RevenueChartControl.xaml" />
    <None Remove="Views\UserControls\PaginationControl.xaml" />
    <None Remove="Views\UserControls\Dashboard\QuickStatsControl.xaml" />
    <None Remove="Views\UserControls\Dashboard\StatCardControl.xaml" />
    <None Remove="Views\UserControls\Dashboard\TrendingListControl.xaml" />
    <None Remove="Views\UserControls\Settings\GeneralSettingsCardControl.xaml" />
    <None Remove="Views\UserControls\Settings\ShopInformationCardControl.xaml" />
  </ItemGroup>
  <ItemGroup>
    <Page Update="Resources\Styles\ScrollBarStyles.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
</Project>
